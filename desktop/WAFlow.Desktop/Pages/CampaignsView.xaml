<UserControl x:Class="WAFlow.Desktop.Pages.CampaignsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="22,20,22,22">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="WhatsApp 自动化群发" Style="{StaticResource PageTitle}"/>
                <TextBlock Text="建立动态字段话术模板，明确选择客户，并创建立即或定时逐人发送任务" Foreground="{StaticResource Muted}" Margin="0,5,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="＋ 新建发送任务" Style="{StaticResource PrimaryButton}" Click="New_Click" VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,14,0,12">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="13" Margin="0,0,7,0"><StackPanel><TextBlock Text="发送任务" Style="{StaticResource LabelText}"/><TextBlock x:Name="CampaignCountText" Text="0" FontSize="20" FontWeight="Bold"/></StackPanel></Border>
            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="13" Margin="0,0,7,0"><StackPanel><TextBlock Text="运行 / 排期" Style="{StaticResource LabelText}"/><TextBlock x:Name="ActiveCountText" Text="0" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Primary}"/></StackPanel></Border>
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="13" Margin="0,0,7,0"><StackPanel><TextBlock Text="已发送" Style="{StaticResource LabelText}"/><TextBlock x:Name="SentCountText" Text="0" FontSize="20" FontWeight="Bold"/></StackPanel></Border>
            <Border Grid.Column="3" Style="{StaticResource Card}" Padding="13"><StackPanel><TextBlock Text="WhatsApp 连接" Style="{StaticResource LabelText}"/><TextBlock x:Name="ConnectionText" Text="未连接" FontSize="14" FontWeight="SemiBold" Foreground="#A15C16" Margin="0,3,0,0"/></StackPanel></Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="10"/><ColumnDefinition Width="1.05*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="1.2*"/></Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <StackPanel Margin="15,14,15,10"><TextBlock Text="发送任务" FontWeight="SemiBold" FontSize="14"/><TextBlock Text="草稿、排期和执行记录" Foreground="{StaticResource Muted}" FontSize="10" Margin="0,3,0,0"/></StackPanel>
                    <ListBox x:Name="CampaignList" Grid.Row="1" BorderThickness="0" SelectionChanged="CampaignList_SelectionChanged">
                        <ListBox.ItemTemplate><DataTemplate>
                            <Border Padding="12,10" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Width="195">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding ScheduleLabel}" Foreground="{StaticResource Muted}" FontSize="10" Margin="0,5,0,0"/>
                                    <TextBlock Text="{Binding StatusLabel}" Foreground="{StaticResource Primary}" FontSize="10" FontWeight="SemiBold" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate></ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="17,15,17,18">
                        <TextBlock Text="话术模板与任务设置" Style="{StaticResource SectionTitle}"/>
                        <TextBlock x:Name="EditHintText" Text="先保存模板，选择客户并预览，再批准建立自动发送任务。" Foreground="{StaticResource Muted}" FontSize="10" Margin="0,4,0,12"/>

                        <TextBlock Text="已保存话术模板" Style="{StaticResource LabelText}"/>
                        <Grid Margin="0,4,0,8"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="6"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="6"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <ComboBox x:Name="SavedTemplateBox" DisplayMemberPath="Name" SelectionChanged="SavedTemplateBox_SelectionChanged"/>
                            <Button Grid.Column="2" Content="新建" Style="{StaticResource SecondaryButton}" Click="NewTemplate_Click" Padding="10,5"/>
                            <Button Grid.Column="4" x:Name="DeleteTemplateButton" Content="删除" Style="{StaticResource DangerButton}" Click="DeleteTemplate_Click" Padding="10,5"/>
                        </Grid>
                        <TextBlock Text="模板名称" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="TemplateNameBox" Margin="0,4,0,8"/>
                        <TextBlock Text="话术内容" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="TemplateBox" AcceptsReturn="True" TextWrapping="Wrap" Height="105" VerticalContentAlignment="Top" Margin="0,4,0,6"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="6"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <ComboBox x:Name="FieldBox" DisplayMemberPath="DisplayLabel" ToolTip="字段来自客户列表、商机数据和导入表格的自定义列"/>
                            <Button Grid.Column="2" Content="插入客户字段" Style="{StaticResource SecondaryButton}" Click="InsertField_Click" Padding="11,5"/>
                        </Grid>
                        <TextBlock Text="群发时会为每位客户生成独立文本；空值会替换为空，不会把字段符号直接发给客户。" Foreground="{StaticResource Muted}" FontSize="9" Margin="0,5,0,6" TextWrapping="Wrap"/>
                        <Button x:Name="SaveTemplateButton" Content="保存话术模板" Style="{StaticResource SecondaryButton}" Click="SaveTemplate_Click" HorizontalAlignment="Left" Padding="12,6"/>

                        <Border Height="1" Background="{StaticResource Line}" Margin="0,13,0,12"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="发送账号" Style="{StaticResource LabelText}"/><ComboBox x:Name="AccountBox" DisplayMemberPath="DisplayLabel" Margin="0,4,0,0"/></StackPanel>
                            <StackPanel Grid.Column="2"><TextBlock Text="任务名称" Style="{StaticResource LabelText}"/><TextBox x:Name="NameBox" Margin="0,4,0,0"/></StackPanel>
                        </Grid>

                        <TextBlock Text="任务触发方式" FontWeight="SemiBold" Margin="0,13,0,6"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="1.35*"/></Grid.ColumnDefinitions>
                            <ComboBox x:Name="ScheduleModeBox" DisplayMemberPath="Label" SelectionChanged="ScheduleModeBox_SelectionChanged"/>
                            <StackPanel x:Name="StartAtPanel" Grid.Column="2"><TextBlock Text="定时开始（北京时间）" Style="{StaticResource LabelText}"/><TextBox x:Name="StartAtBox" ToolTip="例如 2026-07-20 18:30" Margin="0,4,0,0"/></StackPanel>
                        </Grid>

                        <TextBlock Text="逐条发送节奏" FontWeight="SemiBold" Margin="0,13,0,6"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="0.7*"/><ColumnDefinition Width="6"/><ColumnDefinition Width="0.8*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="每隔" Style="{StaticResource LabelText}"/><TextBox x:Name="IntervalBox" Margin="0,4,0,0"/></StackPanel>
                            <ComboBox Grid.Column="2" x:Name="IntervalUnitBox" DisplayMemberPath="Label" VerticalAlignment="Bottom"/>
                            <StackPanel Grid.Column="4"><TextBlock Text="每日上限" Style="{StaticResource LabelText}"/><TextBox x:Name="DailyLimitBox" Margin="0,4,0,0"/></StackPanel>
                        </Grid>

                        <Border Background="{StaticResource WarningSoft}" CornerRadius="8" Padding="10" Margin="0,12,0,11">
                            <TextBlock Text="发送间隔只是节奏控制，不能规避 WhatsApp 风控。仅会向号码有效、已记录营销同意且未退订的客户发送；非官方个人号连接仍可能被限制或封号。" Foreground="#7A5610" FontSize="9" TextWrapping="Wrap"/>
                        </Border>

                        <WrapPanel>
                            <Button x:Name="SaveButton" Content="保存任务草稿" Style="{StaticResource SecondaryButton}" Click="Save_Click" Margin="0,0,7,7"/>
                            <Button x:Name="PreviewButton" Content="预览个性化话术" Style="{StaticResource SecondaryButton}" Click="Preview_Click" Margin="0,0,7,7"/>
                            <Button x:Name="ApproveButton" Content="批准并建立任务" Style="{StaticResource PrimaryButton}" Click="Approve_Click" Margin="0,0,7,7"/>
                            <Button x:Name="PauseResumeButton" Content="暂停" Style="{StaticResource SecondaryButton}" Click="PauseResume_Click" Margin="0,0,7,7" IsEnabled="False"/>
                            <Button x:Name="CancelButton" Content="取消任务" Style="{StaticResource DangerButton}" Click="Cancel_Click" Margin="0,0,0,7" IsEnabled="False"/>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource Card}" Padding="0">
                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <StackPanel Margin="15,13,15,10">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="选择发送客户" FontWeight="SemiBold" FontSize="14"/><TextBlock x:Name="PreviewSummaryText" Text="请勾选一位或多位客户" Foreground="{StaticResource Muted}" FontSize="10" Margin="0,3,0,0"/></StackPanel>
                            <TextBlock Grid.Column="1" x:Name="EligibleCountText" Text="已选 0" Foreground="{StaticResource Primary}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </Grid>
                        <TextBox x:Name="AudienceSearchBox" Margin="0,9,0,7" ToolTip="搜索姓名、公司、号码或标签" TextChanged="AudienceFilter_Changed"/>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="6"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <ComboBox x:Name="CustomerGradeFilterBox" SelectionChanged="AudienceFilter_Changed"/>
                            <ComboBox Grid.Column="2" x:Name="CustomerStageFilterBox" DisplayMemberPath="Label" SelectionChanged="AudienceFilter_Changed"/>
                        </Grid>
                        <WrapPanel Margin="0,7,0,0"><Button Content="全选当前可发送" Style="{StaticResource SecondaryButton}" Click="SelectAllEligible_Click" Padding="10,5" Margin="0,0,6,0"/><Button Content="清空选择" Style="{StaticResource SecondaryButton}" Click="ClearSelection_Click" Padding="10,5"/></WrapPanel>
                    </StackPanel>
                    <DataGrid x:Name="AudienceGrid" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" RowHeight="40" BorderThickness="0,1,0,1" SelectionChanged="AudienceGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="选" Width="38"><DataGridTemplateColumn.CellTemplate><DataTemplate><CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" Click="AudienceCheck_Click" IsEnabled="{Binding Eligible}"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                            <DataGridTextColumn Header="客户" Binding="{Binding DisplayName}" Width="1.05*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="公司" Binding="{Binding Company}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="等级" Binding="{Binding Grade}" Width="48" IsReadOnly="True"/>
                            <DataGridTextColumn Header="状态" Binding="{Binding StatusText}" Width="75" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Grid.Row="2" Background="#F6F9F7" Padding="12">
                        <StackPanel>
                            <TextBlock Text="当前客户个性化预览" Style="{StaticResource LabelText}"/>
                            <TextBlock x:Name="SelectedPreviewText" Text="选择表格中的客户可查看字段替换结果。" TextWrapping="Wrap" MaxHeight="76" Margin="0,4,0,7"/>
                            <TextBlock x:Name="CampaignStateText" Text="新草稿" FontWeight="SemiBold"/>
                            <TextBlock x:Name="PauseReasonText" Text="" Foreground="#A15C16" FontSize="10" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
