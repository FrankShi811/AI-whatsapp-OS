<UserControl x:Class="WAFlow.Desktop.Pages.CampaignsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="24,22,24,24">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Campaign Automation" Style="{StaticResource PageTitle}"/>
                <TextBlock Text="个人号非官方连接 · 仅向已同意且未退订的单聊客户逐条发送" Foreground="{StaticResource Muted}" Margin="0,5,0,0"/>
            </StackPanel>
            <Button Grid.Column="1" Content="＋ 新建 Campaign" Style="{StaticResource PrimaryButton}" Click="New_Click" VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,16,0,14">
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="14" Margin="0,0,8,0"><StackPanel><TextBlock Text="Campaign" Style="{StaticResource LabelText}"/><TextBlock x:Name="CampaignCountText" Text="0" FontSize="20" FontWeight="Bold"/></StackPanel></Border>
            <Border Grid.Column="1" Style="{StaticResource Card}" Padding="14" Margin="0,0,8,0"><StackPanel><TextBlock Text="运行 / 排期" Style="{StaticResource LabelText}"/><TextBlock x:Name="ActiveCountText" Text="0" FontSize="20" FontWeight="Bold" Foreground="{StaticResource Primary}"/></StackPanel></Border>
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="14" Margin="0,0,8,0"><StackPanel><TextBlock Text="已发送" Style="{StaticResource LabelText}"/><TextBlock x:Name="SentCountText" Text="0" FontSize="20" FontWeight="Bold"/></StackPanel></Border>
            <Border Grid.Column="3" Style="{StaticResource Card}" Padding="14"><StackPanel><TextBlock Text="WhatsApp 连接" Style="{StaticResource LabelText}"/><TextBlock x:Name="ConnectionText" Text="未连接" FontSize="15" FontWeight="SemiBold" Foreground="#A15C16" Margin="0,3,0,0"/></StackPanel></Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="245"/><ColumnDefinition Width="12"/><ColumnDefinition Width="1.1*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="0.95*"/></Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <TextBlock Text="Campaign 列表" FontWeight="SemiBold" FontSize="14" Margin="16,15,16,11"/>
                    <ListBox x:Name="CampaignList" Grid.Row="1" BorderThickness="0" SelectionChanged="CampaignList_SelectionChanged">
                        <ListBox.ItemTemplate><DataTemplate>
                            <Border Padding="13,11" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Width="215">
                                <StackPanel>
                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <Grid Margin="0,6,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding ScheduleLabel}" Foreground="{StaticResource Muted}" FontSize="10"/>
                                        <TextBlock Grid.Column="1" Text="{Binding StatusLabel}" Foreground="{StaticResource Primary}" FontSize="10" FontWeight="SemiBold"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </DataTemplate></ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="EditorPanel" Margin="19,17,19,20">
                        <TextBlock Text="编辑与排期" Style="{StaticResource SectionTitle}"/>
                        <TextBlock x:Name="EditHintText" Text="先保存草稿并预览受众，再一次性批准自动发送。" Foreground="{StaticResource Muted}" FontSize="11" Margin="0,4,0,15"/>

                        <TextBlock Text="发送账号" Style="{StaticResource LabelText}"/>
                        <ComboBox x:Name="AccountBox" DisplayMemberPath="DisplayLabel" Margin="0,5,0,12"/>

                        <TextBlock Text="Campaign 名称" Style="{StaticResource LabelText}"/>
                        <TextBox x:Name="NameBox" Margin="0,5,0,12"/>

                        <TextBlock Text="受众筛选" FontWeight="SemiBold" Margin="0,0,0,7"/>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="等级" Style="{StaticResource LabelText}"/><ComboBox x:Name="GradeBox" Margin="0,4,0,0"/></StackPanel>
                            <StackPanel Grid.Column="2"><TextBlock Text="阶段" Style="{StaticResource LabelText}"/><ComboBox x:Name="StageBox" DisplayMemberPath="Label" Margin="0,4,0,0"/></StackPanel>
                        </Grid>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="标签包含（可空）" Style="{StaticResource LabelText}"/><TextBox x:Name="TagBox" Margin="0,4,0,0"/></StackPanel>
                            <StackPanel Grid.Column="2"><TextBlock Text="负责人包含（可空）" Style="{StaticResource LabelText}"/><TextBox x:Name="OwnerBox" Margin="0,4,0,0"/></StackPanel>
                        </Grid>

                        <TextBlock Text="发送话术" FontWeight="SemiBold"/>
                        <TextBox x:Name="TemplateBox" AcceptsReturn="True" TextWrapping="Wrap" Height="112" VerticalContentAlignment="Top" Margin="0,7,0,5"/>
                        <TextBlock Text="可用变量：{name} {company} {country} {product} {owner} {grade} {stage}，也支持上传表格的自定义字段名。" Foreground="{StaticResource Muted}" FontSize="10"/>

                        <TextBlock Text="发送计划（北京时间）" FontWeight="SemiBold" Margin="0,15,0,7"/>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="1.25*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="0.75*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="0.75*"/></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="开始时间" Style="{StaticResource LabelText}"/><TextBox x:Name="StartAtBox" ToolTip="例如 2026-07-18 09:30" Margin="0,4,0,0"/></StackPanel>
                            <StackPanel Grid.Column="2"><TextBlock Text="间隔分钟" Style="{StaticResource LabelText}"/><TextBox x:Name="IntervalBox" Margin="0,4,0,0"/></StackPanel>
                            <StackPanel Grid.Column="4"><TextBlock Text="每日上限" Style="{StaticResource LabelText}"/><TextBox x:Name="DailyLimitBox" Margin="0,4,0,0"/></StackPanel>
                        </Grid>

                        <Border Background="{StaticResource WarningSoft}" CornerRadius="8" Padding="11" Margin="0,14,0,13">
                            <TextBlock Text="非官方个人号连接存在被 WhatsApp 限制或封号的风险。系统不会规避风控；登出、失联或客户退订时会暂停/跳过。批准后将按固定间隔自动逐条发送。" Foreground="#7A5610" FontSize="10"/>
                        </Border>

                        <WrapPanel>
                            <Button x:Name="PreviewButton" Content="预览受众" Style="{StaticResource SecondaryButton}" Click="Preview_Click" Margin="0,0,8,8"/>
                            <Button x:Name="SaveButton" Content="保存草稿" Style="{StaticResource SecondaryButton}" Click="Save_Click" Margin="0,0,8,8"/>
                            <Button x:Name="ApproveButton" Content="批准并排期" Style="{StaticResource PrimaryButton}" Click="Approve_Click" Margin="0,0,8,8"/>
                            <Button x:Name="PauseResumeButton" Content="暂停" Style="{StaticResource SecondaryButton}" Click="PauseResume_Click" Margin="0,0,8,8" IsEnabled="False"/>
                            <Button x:Name="CancelButton" Content="取消" Style="{StaticResource DangerButton}" Click="Cancel_Click" Margin="0,0,0,8" IsEnabled="False"/>
                        </WrapPanel>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="4" Style="{StaticResource Card}" Padding="0">
                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Grid Margin="16,15,16,11"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel><TextBlock Text="逐人预览 / 队列" FontWeight="SemiBold" FontSize="14"/><TextBlock x:Name="PreviewSummaryText" Text="尚未预览" Foreground="{StaticResource Muted}" FontSize="10" Margin="0,3,0,0"/></StackPanel>
                        <TextBlock Grid.Column="1" x:Name="EligibleCountText" Text="0 可发送" Foreground="{StaticResource Primary}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Grid>
                    <DataGrid x:Name="AudienceGrid" Grid.Row="1" IsReadOnly="True" RowHeight="42" BorderThickness="0,1,0,1">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="客户" Binding="{Binding DisplayName}" Width="1.1*"/>
                            <DataGridTextColumn Header="等级" Binding="{Binding Grade}" Width="50"/>
                            <DataGridTextColumn Header="状态" Binding="{Binding StatusText}" Width="75"/>
                            <DataGridTextColumn Header="时间 / 原因" Binding="{Binding Detail}" Width="1.1*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Grid.Row="2" Background="#F6F9F7" Padding="13">
                        <StackPanel><TextBlock Text="当前状态" Style="{StaticResource LabelText}"/><TextBlock x:Name="CampaignStateText" Text="新草稿" FontWeight="SemiBold" Margin="0,3,0,0"/><TextBlock x:Name="PauseReasonText" Text="" Foreground="#A15C16" FontSize="10" Margin="0,3,0,0"/></StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
