<UserControl x:Class="WAFlow.Desktop.Pages.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28,26,28,34">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="销售脉搏" Style="{StaticResource PageTitle}"/>
                    <TextBlock Text="规则评分与 DeepSeek 分析分开记录，所有触达均需人工确认。" Foreground="{StaticResource Muted}" Margin="0,5,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Background="{StaticResource SuccessSoft}" CornerRadius="8" Padding="12,7" VerticalAlignment="Center">
                    <TextBlock Text="● 数据保存在本机" Foreground="#0A7B57" FontSize="12" FontWeight="SemiBold"/>
                </Border>
            </Grid>
            <UniformGrid Columns="4" Margin="0,22,0,0">
                <Border Style="{StaticResource Card}" Margin="0,0,10,0"><StackPanel><TextBlock Text="商机总数" Style="{StaticResource LabelText}"/><TextBlock x:Name="TotalLeadsText" Text="0" FontSize="30" FontWeight="Bold" Margin="0,7,0,0"/><TextBlock Text="本地工作区" Foreground="{StaticResource Muted}" FontSize="11" Margin="0,5,0,0"/></StackPanel></Border>
                <Border Style="{StaticResource Card}" Margin="3,0,7,0"><StackPanel><TextBlock Text="A / B 级商机" Style="{StaticResource LabelText}"/><TextBlock x:Name="HighValueText" Text="0" FontSize="30" FontWeight="Bold" Foreground="{StaticResource Primary}" Margin="0,7,0,0"/><TextBlock Text="优先跟进" Foreground="{StaticResource Muted}" FontSize="11" Margin="0,5,0,0"/></StackPanel></Border>
                <Border Style="{StaticResource Card}" Margin="7,0,3,0"><StackPanel><TextBlock Text="24 小时内待办" Style="{StaticResource LabelText}"/><TextBlock x:Name="FollowUpsText" Text="0" FontSize="30" FontWeight="Bold" Foreground="#B57708" Margin="0,7,0,0"/><TextBlock Text="跟进提醒" Foreground="{StaticResource Muted}" FontSize="11" Margin="0,5,0,0"/></StackPanel></Border>
                <Border Style="{StaticResource Card}" Margin="10,0,0,0"><StackPanel><TextBlock Text="自动化任务" Style="{StaticResource LabelText}"/><TextBlock x:Name="ActiveCampaignsText" Text="0" FontSize="30" FontWeight="Bold" Margin="0,7,0,0"/><TextBlock Text="运行 / 排期 / 暂停 / 安全停止" Foreground="{StaticResource Muted}" FontSize="11" Margin="0,5,0,0"/></StackPanel></Border>
            </UniformGrid>
            <Border Background="#EAF4EF" BorderBrush="#CEE5DA" BorderThickness="1" CornerRadius="9" Padding="13,10" Margin="0,12,0,0">
                <Grid><TextBlock Text="最近导入" FontWeight="SemiBold" Foreground="#17634D"/><TextBlock x:Name="LastImportText" Text="暂无导入记录" HorizontalAlignment="Right" Foreground="#3E6658" FontSize="11"/></Grid>
            </Border>
            <Grid Margin="0,20,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="1.05*"/><ColumnDefinition Width="1.35*"/></Grid.ColumnDefinitions>
                <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="等级分布" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="评分阈值：A≥80 · B 60–79 · C 40–59 · D&lt;40" Style="{StaticResource LabelText}" Margin="0,4,0,16"/>
                        <Grid Height="165">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Bottom" HorizontalAlignment="Center"><Border x:Name="GradeABar" Width="42" Height="20" Background="#128B67" CornerRadius="7,7,0,0"/><TextBlock x:Name="GradeAText" Text="0" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,7,0,0"/><TextBlock Text="A" HorizontalAlignment="Center" Foreground="{StaticResource Muted}"/></StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Center"><Border x:Name="GradeBBar" Width="42" Height="20" Background="#62AA8E" CornerRadius="7,7,0,0"/><TextBlock x:Name="GradeBText" Text="0" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,7,0,0"/><TextBlock Text="B" HorizontalAlignment="Center" Foreground="{StaticResource Muted}"/></StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom" HorizontalAlignment="Center"><Border x:Name="GradeCBar" Width="42" Height="20" Background="#E3B14C" CornerRadius="7,7,0,0"/><TextBlock x:Name="GradeCText" Text="0" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,7,0,0"/><TextBlock Text="C" HorizontalAlignment="Center" Foreground="{StaticResource Muted}"/></StackPanel>
                            <StackPanel Grid.Column="3" VerticalAlignment="Bottom" HorizontalAlignment="Center"><Border x:Name="GradeDBar" Width="42" Height="20" Background="#C96F6F" CornerRadius="7,7,0,0"/><TextBlock x:Name="GradeDText" Text="0" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,7,0,0"/><TextBlock Text="D" HorizontalAlignment="Center" Foreground="{StaticResource Muted}"/></StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="10,0,0,0">
                    <StackPanel>
                        <TextBlock Text="阶段漏斗" Style="{StaticResource SectionTitle}"/>
                        <ItemsControl x:Name="StageItems" Margin="0,14,0,0">
                            <ItemsControl.ItemTemplate><DataTemplate>
                                <Grid Margin="0,5"><Grid.ColumnDefinitions><ColumnDefinition Width="78"/><ColumnDefinition Width="*"/><ColumnDefinition Width="32"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center" Foreground="{StaticResource Muted}"/>
                                    <ProgressBar Grid.Column="1" Height="10" Maximum="100" Value="{Binding Percent}" Foreground="{StaticResource Primary}" Background="#E8EFEB" BorderThickness="0"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Count}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
                                </Grid>
                            </DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>
            <Border Style="{StaticResource Card}" Margin="0,20,0,0">
                <StackPanel>
                    <Grid Margin="0,0,0,12"><TextBlock Text="优先商机" Style="{StaticResource SectionTitle}"/><TextBlock Text="按规则 / AI 分数排序" HorizontalAlignment="Right" Style="{StaticResource LabelText}"/></Grid>
                    <DataGrid x:Name="PriorityGrid" IsReadOnly="True" MaxHeight="285">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="客户" Binding="{Binding DisplayName}" Width="1.25*"/>
                            <DataGridTextColumn Header="公司" Binding="{Binding Company}" Width="1.35*"/>
                            <DataGridTextColumn Header="国家" Binding="{Binding Country}" Width="*"/>
                            <DataGridTextColumn Header="等级" Binding="{Binding Grade}" Width="70"/>
                            <DataGridTextColumn Header="评分" Binding="{Binding Score}" Width="70"/>
                            <DataGridTextColumn Header="阶段" Binding="{Binding StageLabel}" Width="100"/>
                            <DataGridTextColumn Header="下一步" Binding="{Binding NextAction}" Width="2*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
