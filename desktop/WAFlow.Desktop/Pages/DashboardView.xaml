<UserControl x:Class="WAFlow.Desktop.Pages.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:WAFlow.Desktop.Controls">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="30,26,30,38">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="SALES COMMAND CENTER" Style="{StaticResource PageEyebrow}"/>
                    <TextBlock Text="今天应该做什么？" Style="{StaticResource PageTitle}" Margin="0,5,0,0"/>
                    <TextBlock Text="把高价值商机、待跟进客户、AI 分析进度和触达风险压缩到一个可执行视图。" Foreground="{DynamicResource Muted}" Margin="0,6,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{DynamicResource SuccessSoft}" CornerRadius="14" Padding="11,7" Margin="0,0,8,0">
                        <TextBlock Text="●  数据实时保存在本机" Foreground="{DynamicResource Success}" FontSize="10.5" FontWeight="SemiBold"/>
                    </Border>
                    <Button Content="打开 WhatsApp Inbox" Style="{StaticResource PrimaryButton}" Tag="inbox" Click="Action_Click"/>
                </StackPanel>
            </Grid>

            <!-- Executive metrics -->
            <UniformGrid Columns="4" Margin="0,22,0,0">
                <Border Style="{StaticResource MetricCard}" Margin="0,0,7,0">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel><TextBlock Text="全部商机" Style="{StaticResource LabelText}"/><TextBlock x:Name="TotalLeadsText" Text="0" Style="{StaticResource MetricValue}" Margin="0,5,0,0"/><TextBlock Text="统一客户工作区" Foreground="{DynamicResource Muted}" FontSize="10" Margin="0,4,0,0"/></StackPanel>
                        <Border Grid.Column="1" Width="34" Height="34" Background="{DynamicResource PrimarySoft}" CornerRadius="10" VerticalAlignment="Top"><TextBlock Text="◎" Foreground="{DynamicResource Primary}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                    </Grid>
                </Border>
                <Border Style="{StaticResource MetricCard}" Margin="7,0">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel><TextBlock Text="优先商机 A / B" Style="{StaticResource LabelText}"/><TextBlock x:Name="HighValueText" Text="0" Style="{StaticResource MetricValue}" Foreground="{DynamicResource Primary}" Margin="0,5,0,0"/><TextBlock Text="值得优先人工推进" Foreground="{DynamicResource Muted}" FontSize="10" Margin="0,4,0,0"/></StackPanel>
                        <Border Grid.Column="1" Width="34" Height="34" Background="{DynamicResource AiSoft}" CornerRadius="10" VerticalAlignment="Top"><TextBlock Text="✦" Foreground="{DynamicResource AiAccent}" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                    </Grid>
                </Border>
                <Border Style="{StaticResource MetricCard}" Margin="7,0">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel><TextBlock Text="24 小时内待跟进" Style="{StaticResource LabelText}"/><TextBlock x:Name="FollowUpsText" Text="0" Style="{StaticResource MetricValue}" Foreground="{DynamicResource Warning}" Margin="0,5,0,0"/><TextBlock Text="销售承诺与下一步" Foreground="{DynamicResource Muted}" FontSize="10" Margin="0,4,0,0"/></StackPanel>
                        <Border Grid.Column="1" Width="34" Height="34" Background="{DynamicResource WarningSoft}" CornerRadius="10" VerticalAlignment="Top"><TextBlock Text="◷" Foreground="{DynamicResource Warning}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                    </Grid>
                </Border>
                <Border Style="{StaticResource MetricCard}" Margin="7,0,0,0">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel><TextBlock Text="进行中自动化" Style="{StaticResource LabelText}"/><TextBlock x:Name="ActiveCampaignsText" Text="0" Style="{StaticResource MetricValue}" Margin="0,5,0,0"/><TextBlock x:Name="CampaignSafetyText" Text="排期、运行或暂停" Foreground="{DynamicResource Muted}" FontSize="10" Margin="0,4,0,0"/></StackPanel>
                        <Border Grid.Column="1" Width="34" Height="34" Background="{DynamicResource InfoSoft}" CornerRadius="10" VerticalAlignment="Top"><TextBlock Text="◌" Foreground="{DynamicResource Info}" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                    </Grid>
                </Border>
            </UniformGrid>

            <Border Background="{DynamicResource PrimarySurface}" BorderBrush="{DynamicResource PrimarySoft}" BorderThickness="1" CornerRadius="11" Padding="14,10" Margin="0,12,0,0">
                <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="最近导入" FontWeight="SemiBold" Foreground="{DynamicResource Primary}"/><TextBlock Grid.Column="1" x:Name="LastImportText" Text="暂无导入记录" HorizontalAlignment="Right" Foreground="{DynamicResource InkSecondary}" FontSize="10.5"/></Grid>
            </Border>

            <!-- Decisions and visual intelligence -->
            <Grid Margin="0,18,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="1.15*"/><ColumnDefinition Width="1.05*"/><ColumnDefinition Width="1.3*"/></Grid.ColumnDefinitions>

                <Border Style="{StaticResource AiCard}" Margin="0,0,8,0">
                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <Grid><TextBlock Text="AI 分析覆盖" Style="{StaticResource SectionTitle}"/><Border HorizontalAlignment="Right" Background="{DynamicResource AiSoft}" CornerRadius="9" Padding="8,4"><TextBlock x:Name="AnalysisCoverageText" Text="0%" Foreground="{DynamicResource AiAccentDeep}" Style="{StaticResource PillText}"/></Border></Grid>
                        <Grid Grid.Row="1" Margin="0,17,0,14">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <controls:GradeDonut x:Name="GradeDonut" Width="104" Height="104" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="已完成 AI 分析" Style="{StaticResource LabelText}"/>
                                <TextBlock x:Name="AnalyzedLeadsText" Text="0 / 0" FontSize="20" FontWeight="Bold" Margin="0,3,0,10"/>
                                <ProgressBar x:Name="AnalysisCoverageBar" Height="6" Maximum="100"/>
                                <TextBlock x:Name="AnalysisQueueText" Text="无等待任务" Foreground="{DynamicResource Muted}" FontSize="9.5" Margin="0,7,0,0"/>
                            </StackPanel>
                        </Grid>
                        <Button Grid.Row="2" Content="进入商机智能" Style="{StaticResource AiButton}" HorizontalAlignment="Stretch" Tag="intelligence" Click="Action_Click"/>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="8,0">
                    <StackPanel>
                        <Grid><TextBlock Text="等级分布" Style="{StaticResource SectionTitle}"/><TextBlock Text="AI SCORE" HorizontalAlignment="Right" Style="{StaticResource PageEyebrow}"/></Grid>
                        <TextBlock Text="未分析客户保持 D / 0 分" Style="{StaticResource LabelText}" Margin="0,4,0,12"/>
                        <Grid Height="124">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Bottom" HorizontalAlignment="Center"><Border x:Name="GradeABar" Width="30" Height="18" Background="{DynamicResource Primary}" CornerRadius="6,6,0,0"/><TextBlock x:Name="GradeAText" Text="0" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,6,0,0"/><TextBlock Text="A" HorizontalAlignment="Center" Foreground="{DynamicResource Muted}" FontSize="10"/></StackPanel>
                            <StackPanel Grid.Column="1" VerticalAlignment="Bottom" HorizontalAlignment="Center"><Border x:Name="GradeBBar" Width="30" Height="18" Background="#64B294" CornerRadius="6,6,0,0"/><TextBlock x:Name="GradeBText" Text="0" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,6,0,0"/><TextBlock Text="B" HorizontalAlignment="Center" Foreground="{DynamicResource Muted}" FontSize="10"/></StackPanel>
                            <StackPanel Grid.Column="2" VerticalAlignment="Bottom" HorizontalAlignment="Center"><Border x:Name="GradeCBar" Width="30" Height="18" Background="#E7B54D" CornerRadius="6,6,0,0"/><TextBlock x:Name="GradeCText" Text="0" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,6,0,0"/><TextBlock Text="C" HorizontalAlignment="Center" Foreground="{DynamicResource Muted}" FontSize="10"/></StackPanel>
                            <StackPanel Grid.Column="3" VerticalAlignment="Bottom" HorizontalAlignment="Center"><Border x:Name="GradeDBar" Width="30" Height="18" Background="#C96F73" CornerRadius="6,6,0,0"/><TextBlock x:Name="GradeDText" Text="0" HorizontalAlignment="Center" FontWeight="Bold" Margin="0,6,0,0"/><TextBlock Text="D" HorizontalAlignment="Center" Foreground="{DynamicResource Muted}" FontSize="10"/></StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Style="{StaticResource Card}" Margin="8,0,0,0">
                    <StackPanel>
                        <Grid><TextBlock Text="阶段漏斗" Style="{StaticResource SectionTitle}"/><TextBlock Text="PIPELINE" HorizontalAlignment="Right" Style="{StaticResource PageEyebrow}"/></Grid>
                        <ItemsControl x:Name="StageItems" Margin="0,10,0,0">
                            <ItemsControl.ItemTemplate><DataTemplate>
                                <Grid Margin="0,4"><Grid.ColumnDefinitions><ColumnDefinition Width="64"/><ColumnDefinition Width="*"/><ColumnDefinition Width="34"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Label}" VerticalAlignment="Center" Foreground="{DynamicResource Muted}" FontSize="10.5"/>
                                    <ProgressBar Grid.Column="1" Height="7" Maximum="100" Value="{Binding Percent}"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Count}" HorizontalAlignment="Right" FontWeight="SemiBold" FontSize="10.5"/>
                                </Grid>
                            </DataTemplate></ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Work queue -->
            <Grid Margin="0,18,0,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="1.75*"/><ColumnDefinition Width="0.75*"/></Grid.ColumnDefinitions>
                <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,11"><StackPanel><TextBlock Text="今日优先商机" Style="{StaticResource SectionTitle}"/><TextBlock Text="只展示已完成 AI 分析的 A / B 级客户" Style="{StaticResource LabelText}" Margin="0,3,0,0"/></StackPanel><Button Content="查看全部" HorizontalAlignment="Right" VerticalAlignment="Center" Style="{StaticResource GhostButton}" Tag="intelligence" Click="Action_Click"/></Grid>
                        <DataGrid x:Name="PriorityGrid" IsReadOnly="True" MaxHeight="280" MinHeight="175">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="客户" Binding="{Binding DisplayName}" Width="1.15*"/>
                                <DataGridTextColumn Header="市场" Binding="{Binding Country}" Width="0.75*"/>
                                <DataGridTextColumn Header="等级" Binding="{Binding Grade}" Width="54"/>
                                <DataGridTextColumn Header="AI 分数" Binding="{Binding Score}" Width="64"/>
                                <DataGridTextColumn Header="阶段" Binding="{Binding StageLabel}" Width="82"/>
                                <DataGridTextColumn Header="AI 建议下一步" Binding="{Binding NextAction}" Width="2*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Card}" Margin="8,0,0,0">
                    <StackPanel>
                        <Grid><TextBlock Text="触达质量" Style="{StaticResource SectionTitle}"/><Border HorizontalAlignment="Right" Background="{DynamicResource SuccessSoft}" CornerRadius="8" Padding="7,3"><TextBlock Text="LIVE" Foreground="{DynamicResource Success}" FontSize="9" FontWeight="Bold"/></Border></Grid>
                        <TextBlock Text="累计自动化发送结果" Style="{StaticResource LabelText}" Margin="0,4,0,15"/>
                        <Grid Margin="0,0,0,10"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel><TextBlock x:Name="CampaignSentText" Text="0" FontSize="21" FontWeight="Bold" Foreground="{DynamicResource Success}"/><TextBlock Text="成功" Style="{StaticResource LabelText}"/></StackPanel><StackPanel Grid.Column="1"><TextBlock x:Name="CampaignQueuedText" Text="0" FontSize="21" FontWeight="Bold" Foreground="{DynamicResource Info}"/><TextBlock Text="排队" Style="{StaticResource LabelText}"/></StackPanel><StackPanel Grid.Column="2"><TextBlock x:Name="CampaignFailedText" Text="0" FontSize="21" FontWeight="Bold" Foreground="{DynamicResource Danger}"/><TextBlock Text="失败" Style="{StaticResource LabelText}"/></StackPanel></Grid>
                        <Border Background="{DynamicResource WarningSoft}" CornerRadius="9" Padding="11" Margin="0,8,0,12"><TextBlock x:Name="CampaignQualityText" Text="暂无发送历史" Foreground="{DynamicResource Warning}" FontSize="10.5" TextWrapping="Wrap"/></Border>
                        <Button Content="查看自动化任务" Style="{StaticResource SecondaryButton}" HorizontalAlignment="Stretch" Tag="broadcast" Click="Action_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
