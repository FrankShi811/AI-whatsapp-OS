<UserControl x:Class="WAFlow.Desktop.Pages.EmailInboxView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="30,24,30,28"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="17"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="CUSTOMER EMAIL INTELLIGENCE" Style="{StaticResource PageEyebrow}"/>
                <TextBlock Text="邮件 Inbox" Style="{StaticResource PageTitle}" Margin="0,5,0,0"/>
                <TextBlock Text="连接邮箱、收发邮件、保存历史，并通过邮箱地址与客户列表和商机智能共享同一客户资料。" Foreground="{DynamicResource Muted}" Margin="0,6,0,0"/>
            </StackPanel>
            <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                <ComboBox x:Name="AccountBox" Width="235" DisplayMemberPath="DisplayLabel" SelectionChanged="AccountBox_SelectionChanged" Margin="0,0,8,0"/>
                <Button Content="＋ 连接邮箱" Style="{StaticResource SecondaryButton}" Click="AddAccount_Click" Margin="0,0,8,0"/>
                <Button Content="管理账号" Style="{StaticResource SecondaryButton}" Click="ManageAccount_Click" Margin="0,0,8,0"/>
                <Button x:Name="SyncButton" Content="同步收件箱" Style="{StaticResource PrimaryButton}" Click="Sync_Click"/>
            </WrapPanel>
        </Grid>

        <Grid Grid.Row="2"><Grid.ColumnDefinitions><ColumnDefinition Width="285"/><ColumnDefinition Width="12"/><ColumnDefinition Width="*"/><ColumnDefinition Width="12"/><ColumnDefinition Width="360"/></Grid.ColumnDefinitions>
            <Border Style="{StaticResource Card}" Padding="0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <StackPanel Margin="16,15,16,12"><TextBlock Text="邮件会话" Style="{StaticResource SectionTitle}"/><TextBox x:Name="SearchBox" Margin="0,10,0,0" TextChanged="SearchBox_TextChanged" ToolTip="搜索姓名、邮箱、主题或正文"/></StackPanel>
                <ListBox x:Name="ConversationList" Grid.Row="1" BorderThickness="0" SelectionChanged="ConversationList_SelectionChanged">
                    <ListBox.ItemTemplate><DataTemplate><Border Padding="14,11" BorderBrush="{DynamicResource Line}" BorderThickness="0,1,0,0" Width="260"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel><TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/><TextBlock Text="{Binding PeerEmail}" Foreground="{DynamicResource Muted}" FontSize="10" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/><TextBlock Text="{Binding LastMessage}" Foreground="{DynamicResource Muted}" FontSize="10" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/></StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding LastTimeLabel}" Foreground="{DynamicResource Muted}" FontSize="9"/>
                    </Grid></Border></DataTemplate></ListBox.ItemTemplate>
                </ListBox>
            </Grid></Border>

            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Border Padding="18,14" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1"><StackPanel><TextBlock x:Name="ConversationTitle" Text="选择邮件会话" FontWeight="SemiBold" FontSize="17"/><TextBlock x:Name="ConversationSubtitle" Foreground="{DynamicResource Muted}" Margin="0,3,0,0"/></StackPanel></Border>
                <ScrollViewer x:Name="MessageScroll" Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="{DynamicResource SurfaceMuted}"><ItemsControl x:Name="MessageList" Margin="14"><ItemsControl.ItemTemplate><DataTemplate>
                    <Border x:Name="Bubble" BorderThickness="1" CornerRadius="12" Padding="12" Margin="0,5" MaxWidth="640">
                        <Border.Style><Style TargetType="Border"><Setter Property="HorizontalAlignment" Value="Left"/><Setter Property="Background" Value="{DynamicResource Surface}"/><Setter Property="BorderBrush" Value="{DynamicResource Line}"/><Style.Triggers><DataTrigger Binding="{Binding DirectionLabel}" Value="已发送"><Setter Property="HorizontalAlignment" Value="Right"/><Setter Property="Background" Value="{DynamicResource PrimarySoft}"/><Setter Property="BorderBrush" Value="{DynamicResource PrimarySoft}"/></DataTrigger></Style.Triggers></Style></Border.Style>
                        <StackPanel><TextBlock Text="{Binding Subject}" FontWeight="SemiBold" TextWrapping="Wrap"/><TextBlock Text="{Binding TextBody}" Margin="0,7,0,0" TextWrapping="Wrap"/><TextBlock Text="{Binding DirectionLabel}" Foreground="{DynamicResource Muted}" FontSize="9" HorizontalAlignment="Right" Margin="0,7,0,0"/><TextBlock Text="{Binding TimeLabel}" Foreground="{DynamicResource Muted}" FontSize="9" HorizontalAlignment="Right"/></StackPanel>
                    </Border>
                </DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer>
                <Border Grid.Row="2" Padding="15" BorderBrush="{DynamicResource Line}" BorderThickness="0,1,0,0"><StackPanel>
                    <TextBox x:Name="SubjectBox" ToolTip="邮件主题" Margin="0,0,0,7"/>
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="10"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBox x:Name="ComposerBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="64" VerticalContentAlignment="Top" ToolTip="邮件正文"/>
                        <Button Grid.Column="2" x:Name="SendButton" Content="发送邮件" Style="{StaticResource PrimaryButton}" Click="Send_Click" VerticalAlignment="Stretch"/>
                    </Grid>
                </StackPanel></Border>
            </Grid></Border>

            <Border Grid.Column="4" Style="{StaticResource Card}" Padding="0"><Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <Border Padding="17,14" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1"><StackPanel><TextBlock Text="Customer Intelligence" FontWeight="SemiBold" FontSize="17"/><TextBlock x:Name="LinkStateText" Text="按邮箱自动匹配客户" Foreground="{DynamicResource Muted}" Margin="0,3,0,0"/></StackPanel></Border>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"><StackPanel Margin="17,15">
                    <Border Background="{DynamicResource PrimarySoft}" CornerRadius="12" Padding="12"><StackPanel><TextBlock Text="邮件与 CRM 已联动" Foreground="{DynamicResource Primary}" FontWeight="SemiBold"/><TextBlock Text="保存后，客户列表、商机智能、客户分析和邮件自动化任务都会读取这份资料。" Foreground="{DynamicResource Muted}" FontSize="10" TextWrapping="Wrap" Margin="0,4,0,0"/></StackPanel></Border>
                    <TextBlock Text="姓名" Style="{StaticResource LabelText}" Margin="0,14,0,4"/><TextBox x:Name="NameBox"/>
                    <TextBlock Text="邮箱" Style="{StaticResource LabelText}" Margin="0,10,0,4"/><TextBox x:Name="CustomerEmailBox"/>
                    <TextBlock Text="公司" Style="{StaticResource LabelText}" Margin="0,10,0,4"/><TextBox x:Name="CompanyBox"/>
                    <TextBlock Text="国家 / 地区" Style="{StaticResource LabelText}" Margin="0,10,0,4"/><TextBox x:Name="CountryBox"/>
                    <TextBlock Text="阶段" Style="{StaticResource LabelText}" Margin="0,10,0,4"/><ComboBox x:Name="StageBox" DisplayMemberPath="Label"/>
                    <TextBlock Text="负责人" Style="{StaticResource LabelText}" Margin="0,10,0,4"/><TextBox x:Name="OwnerBox"/>
                    <TextBlock Text="标签（逗号分隔）" Style="{StaticResource LabelText}" Margin="0,10,0,4"/><TextBox x:Name="TagsBox"/>
                    <TextBlock Text="备注 / 最近情况" Style="{StaticResource LabelText}" Margin="0,10,0,4"/><TextBox x:Name="NotesBox" AcceptsReturn="True" TextWrapping="Wrap" Height="100" VerticalContentAlignment="Top"/>
                </StackPanel></ScrollViewer>
                <Button Grid.Row="2" x:Name="SaveCustomerButton" Content="保存并同步客户" Style="{StaticResource PrimaryButton}" Click="SaveCustomer_Click" Margin="15"/>
            </Grid></Border>
        </Grid>
    </Grid>
</UserControl>
