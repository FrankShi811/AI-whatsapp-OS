<UserControl x:Class="WAFlow.Desktop.Pages.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style x:Key="CustomerCellText" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="NoWrap"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="ToolTip" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
        </Style>
    </UserControl.Resources>
    <Grid Margin="28,26,28,28">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel><TextBlock Text="客户列表" Style="{StaticResource PageTitle}"/><TextBlock Text="上传表格的每一列都会直接显示；双击客户可逐字段修改。" Foreground="{StaticResource Muted}" Margin="0,5,0,0"/></StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="EditButton" Content="编辑选中客户" Style="{StaticResource SecondaryButton}" Click="Edit_Click" IsEnabled="False" Margin="0,0,8,0"/>
                <Button Content="＋ 导入客户" Style="{StaticResource PrimaryButton}" Click="Import_Click"/>
            </StackPanel>
        </Grid>
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="14" Margin="0,20,0,14">
            <WrapPanel>
                <TextBox x:Name="SearchBox" Width="210" ToolTip="搜索所有字段（含自定义维度）" Margin="0,0,10,8" KeyDown="SearchBox_KeyDown"/>
                <ComboBox x:Name="GradeFilter" Width="105" Margin="0,0,10,8" SelectionChanged="Filter_SelectionChanged"/>
                <ComboBox x:Name="StageFilter" Width="125" Margin="0,0,10,8" DisplayMemberPath="Label" SelectionChanged="Filter_SelectionChanged"/>
                <TextBox x:Name="TagFilterBox" Width="120" ToolTip="标签包含" Margin="0,0,10,8" KeyDown="SearchBox_KeyDown"/>
                <TextBox x:Name="OwnerFilterBox" Width="130" ToolTip="负责人包含" Margin="0,0,10,8" KeyDown="SearchBox_KeyDown"/>
                <ComboBox x:Name="CustomFieldFilter" Width="165" ToolTip="选择自定义维度" Margin="0,0,10,8" SelectionChanged="Filter_SelectionChanged"/>
                <TextBox x:Name="CustomValueFilterBox" Width="145" ToolTip="自定义维度值包含" Margin="0,0,10,8" KeyDown="SearchBox_KeyDown"/>
                <Button Content="清除筛选" Style="{StaticResource SecondaryButton}" Click="Clear_Click" Margin="0,0,0,8"/>
            </WrapPanel>
        </Border>
        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0">
            <Grid>
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                <Border Background="#F8FBF9" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="14,9">
                    <TextBlock x:Name="ListStatsText" Foreground="{StaticResource Muted}" TextWrapping="NoWrap"/>
                </Border>
                <DataGrid x:Name="CustomerGrid" Grid.Row="1" IsReadOnly="True" EnableRowVirtualization="True" EnableColumnVirtualization="True"
                          ScrollViewer.CanContentScroll="True" ScrollViewer.HorizontalScrollBarVisibility="Auto" ScrollViewer.VerticalScrollBarVisibility="Auto"
                          FrozenColumnCount="1" SelectionChanged="CustomerGrid_SelectionChanged" MouseDoubleClick="CustomerGrid_MouseDoubleClick">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="客户" Binding="{Binding DisplayName}" Width="170" ElementStyle="{StaticResource CustomerCellText}"/>
                    <DataGridTextColumn Header="公司" Binding="{Binding Company}" Width="170" ElementStyle="{StaticResource CustomerCellText}"/>
                    <DataGridTextColumn Header="国家 / 地区" Binding="{Binding Country}" Width="120" ElementStyle="{StaticResource CustomerCellText}"/>
                    <DataGridTextColumn Header="WhatsApp" Binding="{Binding PhoneE164}" Width="145" ElementStyle="{StaticResource CustomerCellText}"/>
                    <DataGridTextColumn Header="号码" Binding="{Binding PhoneState}" Width="65" ElementStyle="{StaticResource CustomerCellText}"/>
                    <DataGridTextColumn Header="标签" Binding="{Binding TagsLabel}" Width="150" ElementStyle="{StaticResource CustomerCellText}"/>
                    <DataGridTextColumn Header="负责人" Binding="{Binding Owner}" Width="110" ElementStyle="{StaticResource CustomerCellText}"/>
                    <DataGridTextColumn Header="等级" Binding="{Binding Grade}" Width="60" ElementStyle="{StaticResource CustomerCellText}"/>
                    <DataGridTextColumn Header="阶段" Binding="{Binding StageLabel}" Width="90" ElementStyle="{StaticResource CustomerCellText}"/>
                </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
