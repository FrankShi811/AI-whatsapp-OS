<UserControl x:Class="WAFlow.Desktop.Pages.AnalyticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="28,24,28,26">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="CUSTOMER INTELLIGENCE REPORT" Style="{StaticResource PageEyebrow}"/>
                <TextBlock Text="客户智能分析中心" Style="{StaticResource PageTitle}" Margin="0,5,0,0"/>
                <TextBlock Text="整合 CRM、WhatsApp、商机评分、自动化触达与客户轨迹，生成可供管理层直接使用的专业中文报告。" Foreground="{DynamicResource Muted}" Margin="0,6,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="CompareButton" Content="版本对比" Style="{StaticResource SecondaryButton}" Click="Compare_Click" Margin="0,0,8,0" IsEnabled="False"/>
                <Button x:Name="ExportWordButton" Content="导出 Word" Style="{StaticResource SecondaryButton}" Click="ExportWord_Click" Margin="0,0,8,0" IsEnabled="False"/>
                <Button x:Name="ExportPdfButton" Content="导出 PDF" Style="{StaticResource SecondaryButton}" Click="ExportPdf_Click" Margin="0,0,8,0" IsEnabled="False"/>
                <Button x:Name="GenerateButton" Content="✦  一键生成报告" Style="{StaticResource AiButton}" Click="Generate_Click" IsEnabled="False"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" x:Name="ProgressPanel" Style="{StaticResource AiCard}" Padding="14,11" Margin="0,17,0,14" Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock Text="✦" Foreground="{DynamicResource AiAccent}" FontSize="15" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="ProgressText" Text="正在准备客户数据" FontWeight="SemiBold"/>
                    <ProgressBar x:Name="GenerationProgress" Height="5" Minimum="0" Maximum="5" Value="0" Foreground="{DynamicResource AiAccent}" Margin="0,6,16,0"/>
                </StackPanel>
                <Button Grid.Column="2" x:Name="CancelButton" Content="停止" Style="{StaticResource GhostButton}" Click="Cancel_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="205" MinWidth="185"/>
                <ColumnDefinition Width="*" MinWidth="410"/>
                <ColumnDefinition Width="260" MinWidth="230"/>
            </Grid.ColumnDefinitions>

            <!-- Customer and version rail -->
            <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="2*"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Border Padding="13" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1">
                        <StackPanel>
                            <TextBlock Text="选择客户" Style="{StaticResource SectionTitle}"/>
                            <Grid Margin="0,9,0,0">
                                <TextBlock Text="⌕" Foreground="{DynamicResource Muted}" VerticalAlignment="Center" Margin="9,0,0,0" IsHitTestVisible="False" Panel.ZIndex="1"/>
                                <TextBox x:Name="SearchBox" Padding="27,7,8,7" ToolTip="搜索客户、国家或号码" TextChanged="SearchBox_TextChanged"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    <ListBox Grid.Row="1" x:Name="CustomerList" BorderThickness="0" SelectionChanged="CustomerList_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="5,6">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Country}" Foreground="{DynamicResource Muted}" FontSize="9.5" Margin="0,3,0,0" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="{DynamicResource SurfaceMuted}" CornerRadius="9" Padding="6,2" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Grade, StringFormat={}{0}级}" FontSize="9" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <Border Grid.Row="2" Background="{DynamicResource SurfaceMuted}" Padding="13,10" BorderBrush="{DynamicResource Line}" BorderThickness="0,1">
                        <Grid><TextBlock Text="报告版本" Style="{StaticResource SectionTitle}"/><TextBlock x:Name="VersionCountText" HorizontalAlignment="Right" Style="{StaticResource LabelText}" Text="0 份"/></Grid>
                    </Border>
                    <ListBox Grid.Row="3" x:Name="HistoryList" BorderThickness="0" SelectionChanged="HistoryList_SelectionChanged" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="5,6">
                                    <TextBlock Text="{Binding VersionLabel}" FontWeight="SemiBold" FontSize="10.5"/>
                                    <TextBlock Text="{Binding StatusLabel}" Foreground="{DynamicResource Muted}" FontSize="9.5" Margin="0,2,0,0"/>
                                    <TextBlock Text="{Binding AiModel}" Foreground="{DynamicResource AiAccent}" FontSize="9" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <!-- Professional report canvas -->
            <Border Grid.Column="1" Style="{StaticResource ElevatedCard}" Padding="0" Margin="0,0,12,0">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Border Padding="19,15" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock x:Name="CustomerNameText" Text="请选择客户" FontSize="19" FontWeight="Bold"/>
                                <TextBlock x:Name="CustomerMetaText" Text="生成报告后，这里会显示客户情报摘要" Foreground="{DynamicResource Muted}" FontSize="10" Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="14,0" VerticalAlignment="Center"><TextBlock Text="等级" Style="{StaticResource LabelText}"/><TextBlock x:Name="GradeText" Text="—" FontSize="17" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,2,0,0"/></StackPanel>
                            <StackPanel Grid.Column="2" Margin="14,0" VerticalAlignment="Center"><TextBlock Text="AI 评分" Style="{StaticResource LabelText}"/><TextBlock x:Name="ScoreText" Text="—" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource AiAccent}" HorizontalAlignment="Center" Margin="0,2,0,0"/></StackPanel>
                            <StackPanel Grid.Column="3" Margin="14,0,0,0" VerticalAlignment="Center"><TextBlock Text="成交概率" Style="{StaticResource LabelText}"/><TextBlock x:Name="ProbabilityText" Text="—" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource Success}" HorizontalAlignment="Center" Margin="0,2,0,0"/></StackPanel>
                        </Grid>
                    </Border>
                    <Grid Grid.Row="1">
                        <StackPanel x:Name="EmptyReportPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Width="340">
                            <Border Width="54" Height="54" CornerRadius="16" Background="{DynamicResource AiSurface}" HorizontalAlignment="Center"><TextBlock Text="✦" Foreground="{DynamicResource AiAccent}" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                            <TextBlock Text="建立第一份客户情报报告" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                            <TextBlock Text="系统将分阶段整理全部客户数据、提取事实、完成商业分析与销售策略，再渲染为结构化报告。" TextWrapping="Wrap" TextAlignment="Center" Foreground="{DynamicResource Muted}" LineHeight="20" Margin="0,8,0,0"/>
                        </StackPanel>
                        <ScrollViewer x:Name="ReportScroll" Visibility="Collapsed" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="ReportPanel" Margin="17,17,17,24"/>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>

            <!-- Decision support rail -->
            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="17,17,17,22">
                        <TextBlock Text="AI SALES BRIEF" Style="{StaticResource PageEyebrow}"/>
                        <TextBlock Text="接下来应该做什么" FontSize="17" FontWeight="Bold" Margin="0,5,0,0"/>

                        <Border Style="{StaticResource AiCard}" Padding="13" Margin="0,15,0,0">
                            <StackPanel>
                                <TextBlock Text="下一步行动" Style="{StaticResource SectionTitle}"/>
                                <ItemsControl x:Name="ActionItems" Margin="0,7,0,0">
                                    <ItemsControl.ItemTemplate><DataTemplate><Border BorderBrush="{DynamicResource AiSoft}" BorderThickness="0,0,0,1" Padding="0,7"><StackPanel><TextBlock Text="{Binding Timeframe}" Foreground="{DynamicResource AiAccent}" FontSize="9.5" FontWeight="SemiBold"/><TextBlock Text="{Binding Action}" TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,3,0,0"/><TextBlock Text="{Binding SuccessCriterion}" TextWrapping="Wrap" Foreground="{DynamicResource Muted}" FontSize="9" Margin="0,3,0,0"/></StackPanel></Border></DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="推荐话术" Style="{StaticResource SectionTitle}" Margin="0,17,0,0"/>
                        <TextBlock x:Name="TalkTrackText" Text="生成报告后显示" TextWrapping="Wrap" Foreground="{DynamicResource InkSecondary}" LineHeight="19" Margin="0,7,0,0"/>

                        <TextBlock Text="待解决问题" Style="{StaticResource SectionTitle}" Margin="0,17,0,0"/>
                        <ItemsControl x:Name="PendingQuestionItems" Margin="0,6,0,0"><ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding StringFormat=• {0}}" TextWrapping="Wrap" Foreground="{DynamicResource InkSecondary}" Margin="0,3"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>

                        <Border Background="{DynamicResource SurfaceMuted}" CornerRadius="11" Padding="13" Margin="0,17,0,0">
                            <StackPanel>
                                <TextBlock Text="数据覆盖" Style="{StaticResource SectionTitle}"/>
                                <TextBlock x:Name="CoverageText" Text="等待选择客户" TextWrapping="Wrap" Foreground="{DynamicResource Muted}" LineHeight="18" Margin="0,7,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource WarningSoft}" CornerRadius="11" Padding="13" Margin="0,12,0,0">
                            <StackPanel><TextBlock Text="证据边界" FontWeight="SemiBold" Foreground="{DynamicResource Warning}"/><TextBlock Text="报告明确区分事实、AI 判断与销售建议；缺少证据的结论必须标记为待验证。" TextWrapping="Wrap" Foreground="{DynamicResource InkSecondary}" FontSize="9.5" LineHeight="17" Margin="0,5,0,0"/></StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
