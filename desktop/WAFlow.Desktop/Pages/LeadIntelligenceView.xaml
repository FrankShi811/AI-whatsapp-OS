<UserControl x:Class="WAFlow.Desktop.Pages.LeadIntelligenceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:WAFlow.Desktop.Controls">
    <Grid Margin="30,26,30,28">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="AI LEAD INTELLIGENCE" Style="{StaticResource PageEyebrow}"/>
                <TextBlock Text="把客户数据变成下一步行动" Style="{StaticResource PageTitle}" Margin="0,5,0,0"/>
                <TextBlock Text="分数不是结论：每次 AI 判断同时展示置信度、行为信号、证据、风险与建议。" Foreground="{DynamicResource Muted}" Margin="0,6,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BulkAnalyzeButton" Content="✦  AI 分析 / 重试全部" Style="{StaticResource AiButton}" Click="BulkAnalyze_Click" Margin="0,0,8,0"/>
                    <Button x:Name="CancelBulkButton" Content="停止分析" Style="{StaticResource DangerButton}" Click="CancelBulk_Click" Margin="0,0,8,0" Visibility="Collapsed"/>
                    <Button x:Name="ImportButton" Content="＋  导入客户" Style="{StaticResource SecondaryButton}" Click="Import_Click"/>
                </StackPanel>
                <StackPanel x:Name="BulkProgressPanel" Margin="0,9,0,0" Visibility="Collapsed">
                    <ProgressBar x:Name="BulkProgressBar" Height="5" Minimum="0" Maximum="1" Value="0" Foreground="{DynamicResource AiAccent}"/>
                    <TextBlock x:Name="BulkProgressText" Text="准备批量分析" Foreground="{DynamicResource Muted}" FontSize="9.5" HorizontalAlignment="Right" Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12" Margin="0,19,0,14">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="150"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <Grid>
                    <TextBlock Text="⌕" FontSize="16" Foreground="{DynamicResource Muted}" VerticalAlignment="Center" Margin="11,0,0,0" Panel.ZIndex="1" IsHitTestVisible="False"/>
                    <TextBox x:Name="SearchBox" ToolTip="搜索姓名、公司或号码" Padding="34,8,11,8" Margin="0,0,10,0" KeyDown="SearchBox_KeyDown"/>
                </Grid>
                <ComboBox x:Name="GradeFilter" Grid.Column="1" SelectionChanged="GradeFilter_SelectionChanged" Margin="0,0,10,0"/>
                <Button Grid.Column="2" Content="↻  刷新" Style="{StaticResource SecondaryButton}" Click="Refresh_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions><ColumnDefinition Width="1.65*" MinWidth="570"/><ColumnDefinition x:Name="DecisionSidebarColumn" Width="430"/></Grid.ColumnDefinitions>

            <Border Style="{StaticResource Card}" Padding="0" Margin="0,0,14,0">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Grid Margin="17,13">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal"><TextBlock Text="商机队列" Style="{StaticResource SectionTitle}"/><Border Background="{DynamicResource SurfaceMuted}" CornerRadius="8" Padding="7,3" Margin="9,0,0,0"><TextBlock Text="按 AI 优先级决策" Style="{StaticResource LabelText}"/></Border></StackPanel>
                        <TextBlock Grid.Column="1" Text="选择客户查看 AI 决策层" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                    </Grid>
                    <DataGrid Grid.Row="1" x:Name="LeadGrid" IsReadOnly="True" SelectionChanged="LeadGrid_SelectionChanged" BorderThickness="0,1,0,0" BorderBrush="{DynamicResource Line}" MinHeight="350">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="客户" Binding="{Binding DisplayName}" Width="1.35*"/>
                            <DataGridTextColumn Header="公司" Binding="{Binding Company}" Width="1.15*"/>
                            <DataGridTextColumn Header="市场" Binding="{Binding Country}" Width="0.8*"/>
                            <DataGridTextColumn Header="等级" Binding="{Binding Grade}" Width="52"/>
                            <DataGridTextColumn Header="AI 分数" Binding="{Binding Score}" Width="64"/>
                            <DataGridTextColumn Header="阶段" Binding="{Binding StageLabel}" Width="82"/>
                            <DataGridTextColumn Header="分析状态" Binding="{Binding AnalysisStateLabel}" Width="135"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Grid.Row="2" Background="{DynamicResource SurfaceMuted}" CornerRadius="0,0,16,16" Padding="16,10">
                        <TextBlock Text="未分析客户始终保持 D / 0 分；只有结构化 AI 结果通过校验后才更新。" Foreground="{DynamicResource Muted}" FontSize="9.5"/>
                    </Border>
                </Grid>
            </Border>

            <!-- AI decision layer -->
            <Grid Grid.Column="1">
            <Border x:Name="DecisionDrawerCollapsedRail" Style="{StaticResource Card}" Padding="0" Visibility="Collapsed">
                <Button Content="‹" Style="{StaticResource SecondaryButton}" Click="ToggleDecisionDrawer_Click" Width="32" Height="54" Padding="0" Margin="4,14" FontSize="22" VerticalAlignment="Top" ToolTip="展开 AI 决策侧栏" AutomationProperties.Name="展开 AI 决策侧栏"/>
            </Border>
            <Border x:Name="DecisionSidebarBorder" Style="{StaticResource ElevatedCard}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Border Padding="20,17" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="AI DECISION BRIEF" Style="{StaticResource PageEyebrow}"/>
                                <TextBlock x:Name="LeadNameText" Text="选择一个商机" FontSize="19" FontWeight="Bold" Margin="0,4,0,0"/>
                                <TextBlock x:Name="CompanyText" Foreground="{DynamicResource Muted}" FontSize="10.5" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Border x:Name="GradeBadge" Grid.Column="1" Background="{DynamicResource DangerSoft}" CornerRadius="18" Padding="12,7" Margin="0,0,10,0" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal"><TextBlock x:Name="ScoreText" Text="0" FontSize="17" FontWeight="Bold"/><TextBlock Text=" / 100 · " Foreground="{DynamicResource Muted}" FontSize="10" VerticalAlignment="Bottom" Margin="2,0,0,3"/><TextBlock x:Name="GradeText" Text="—" FontWeight="Bold" VerticalAlignment="Center"/></StackPanel>
                            </Border>
                            <Button Grid.Column="2" Content="›" Style="{StaticResource SecondaryButton}" Click="ToggleDecisionDrawer_Click" Width="32" Height="32" Padding="0" FontSize="20" VerticalAlignment="Center" ToolTip="收起 AI 决策侧栏" AutomationProperties.Name="收起 AI 决策侧栏"/>
                        </Grid>
                    </Border>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="20,18,20,24">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="155"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <controls:ScoreRing x:Name="ScoreRing" Width="145" Height="145"/>
                                <StackPanel Grid.Column="1" Margin="16,4,0,0">
                                    <TextBlock Text="AI 置信度" Style="{StaticResource LabelText}"/>
                                    <TextBlock x:Name="ConfidenceText" Text="0%" FontSize="20" FontWeight="Bold" Margin="0,3,0,6"/>
                                    <ProgressBar x:Name="ConfidenceBar" Height="6" Maximum="100" Foreground="{DynamicResource AiAccent}"/>
                                    <Grid Margin="0,14,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="阶段" Style="{StaticResource LabelText}"/><TextBlock x:Name="StageText" Text="—" FontWeight="SemiBold" Margin="0,3,0,0"/></StackPanel><StackPanel Grid.Column="1"><TextBlock Text="预估订单" Style="{StaticResource LabelText}"/><TextBlock x:Name="AmountText" Text="—" FontWeight="SemiBold" Margin="0,3,0,0"/></StackPanel></Grid>
                                    <Grid Margin="0,13,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><StackPanel><TextBlock Text="画像基础分" Style="{StaticResource LabelText}"/><TextBlock x:Name="BaseScoreText" Text="0 / 100" FontWeight="SemiBold" Margin="0,3,0,0"/></StackPanel><StackPanel Grid.Column="1"><TextBlock Text="行为修正" Style="{StaticResource LabelText}"/><TextBlock x:Name="BehaviorScoreText" Text="0" FontWeight="SemiBold" Margin="0,3,0,0"/></StackPanel></Grid>
                                </StackPanel>
                            </Grid>

                            <TextBlock x:Name="AnalysisMetaText" Foreground="{DynamicResource Muted}" FontSize="9.5" Margin="0,9,0,0" TextWrapping="Wrap"/>

                            <Border Style="{StaticResource AiCard}" Padding="14" Margin="0,16,0,0">
                                <StackPanel>
                                    <TextBlock Text="AI 客户画像" Style="{StaticResource SectionTitle}"/>
                                    <TextBlock x:Name="ProfileText" Text="尚未分析" Foreground="{DynamicResource InkSecondary}" LineHeight="20" Margin="0,7,0,0"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="为什么值得关注" Style="{StaticResource SectionTitle}" Margin="0,18,0,0"/>
                            <ItemsControl x:Name="SignalItems" Margin="0,8,0,0">
                                <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate><DataTemplate><Border Background="{DynamicResource PrimarySoft}" CornerRadius="9" Padding="8,5" Margin="0,0,6,6"><TextBlock Text="{Binding}" Foreground="{DynamicResource PrimaryDark}" FontSize="9.5"/></Border></DataTemplate></ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Background="{DynamicResource PrimarySurface}" BorderBrush="{DynamicResource PrimarySoft}" BorderThickness="1" CornerRadius="11" Padding="14" Margin="0,13,0,0">
                                <StackPanel><TextBlock Text="NEXT BEST ACTION" Style="{StaticResource PageEyebrow}" Foreground="{DynamicResource Primary}"/><TextBlock x:Name="NextActionText" Text="—" Foreground="{DynamicResource Ink}" FontWeight="SemiBold" LineHeight="20" Margin="0,7,0,0"/></StackPanel>
                            </Border>

                            <Grid Margin="0,18,0,0"><TextBlock Text="六维商机雷达" Style="{StaticResource SectionTitle}"/><TextBlock Text="画像分布" HorizontalAlignment="Right" Style="{StaticResource LabelText}"/></Grid>
                            <controls:LeadRadar x:Name="RadarChart" Height="190" Margin="0,7,0,0"/>

                            <TextBlock Text="评分证据" Style="{StaticResource SectionTitle}" Margin="0,12,0,0"/>
                            <ItemsControl x:Name="FactorItems" Margin="0,7,0,0"><ItemsControl.ItemTemplate><DataTemplate>
                                <Border BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="0,9"><StackPanel>
                                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="105"/><ColumnDefinition Width="*"/><ColumnDefinition Width="42"/></Grid.ColumnDefinitions><TextBlock Text="{Binding Label}" Foreground="{DynamicResource InkSecondary}" FontSize="10.5" VerticalAlignment="Center"/><ProgressBar Grid.Column="1" Height="6" Maximum="100" Value="{Binding Percent, Mode=OneWay}" VerticalAlignment="Center"/><TextBlock Grid.Column="2" Text="{Binding Value}" HorizontalAlignment="Right" FontSize="10.5" FontWeight="SemiBold"/></Grid>
                                    <TextBlock Text="{Binding Reason}" TextWrapping="Wrap" FontSize="9.5" Margin="0,5,0,0"/><TextBlock Text="{Binding Evidence}" TextWrapping="Wrap" Foreground="{DynamicResource Muted}" FontSize="9.5" Margin="0,2,0,0"/>
                                </StackPanel></Border>
                            </DataTemplate></ItemsControl.ItemTemplate></ItemsControl>

                            <Border Background="{DynamicResource WarningSoft}" CornerRadius="11" Padding="14" Margin="0,17,0,0">
                                <StackPanel><TextBlock Text="风险与人工复核" Style="{StaticResource SectionTitle}" Foreground="{DynamicResource Warning}"/><ItemsControl x:Name="RiskItems" Margin="0,6,0,0"><ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding StringFormat=• {0}}" Foreground="{DynamicResource InkSecondary}" FontSize="10.5" Margin="0,2"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel>
                            </Border>
                            <TextBlock x:Name="AnalysisErrorText" Foreground="{DynamicResource Danger}" Margin="0,11,0,0"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
