<Window x:Class="WAFlow.Desktop.Windows.EmailAccountWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="连接邮件账号" Width="640" Height="720" MinWidth="580" MinHeight="650"
        WindowStartupLocation="CenterOwner" Icon="/Assets/AI-Sales-OS.ico" Background="{DynamicResource Canvas}">
    <Grid Margin="24"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <StackPanel>
            <TextBlock Text="连接邮件账号" Style="{StaticResource PageTitle}" FontSize="26"/>
            <TextBlock Text="通过 IMAP 收取、SMTP 发送；密码或应用专用密码只保存到 Windows 凭据管理器。" Foreground="{DynamicResource Muted}" Margin="0,6,0,14" TextWrapping="Wrap"/>
        </StackPanel>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Style="{StaticResource Card}" Margin="0,0,0,12"><StackPanel>
                    <TextBlock Text="账号资料" Style="{StaticResource SectionTitle}"/>
                    <TextBlock Text="邮件平台" Style="{StaticResource LabelText}" Margin="0,12,0,4"/><ComboBox x:Name="ProviderBox" DisplayMemberPath="Label" SelectionChanged="ProviderBox_SelectionChanged"/>
                    <TextBlock Text="显示名称" Style="{StaticResource LabelText}" Margin="0,10,0,4"/><TextBox x:Name="DisplayNameBox"/>
                    <TextBlock Text="邮箱地址" Style="{StaticResource LabelText}" Margin="0,10,0,4"/><TextBox x:Name="EmailBox"/>
                    <TextBlock Text="登录用户名" Style="{StaticResource LabelText}" Margin="0,10,0,4"/><TextBox x:Name="UserNameBox"/>
                    <TextBlock Text="密码 / 应用专用密码" Style="{StaticResource LabelText}" Margin="0,10,0,4"/><PasswordBox x:Name="PasswordBox"/>
                    <TextBlock Text="Gmail、Yahoo、iCloud 等通常要求开启 IMAP 并使用应用专用密码；本版不在软件内保存 OAuth 令牌。" Foreground="{DynamicResource Warning}" FontSize="10" TextWrapping="Wrap" Margin="0,7,0,0"/>
                </StackPanel></Border>
                <Border Style="{StaticResource Card}"><StackPanel>
                    <TextBlock Text="收发服务器" Style="{StaticResource SectionTitle}"/>
                    <Grid Margin="0,12,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="95"/></Grid.ColumnDefinitions>
                        <StackPanel><TextBlock Text="IMAP 主机" Style="{StaticResource LabelText}"/><TextBox x:Name="ImapHostBox" Margin="0,4,0,0"/></StackPanel>
                        <StackPanel Grid.Column="2"><TextBlock Text="端口" Style="{StaticResource LabelText}"/><TextBox x:Name="ImapPortBox" Margin="0,4,0,0"/></StackPanel>
                    </Grid>
                    <CheckBox x:Name="ImapSslBox" Content="IMAP 使用 SSL / TLS" Margin="0,8,0,0" IsChecked="True"/>
                    <Grid Margin="0,12,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="8"/><ColumnDefinition Width="95"/></Grid.ColumnDefinitions>
                        <StackPanel><TextBlock Text="SMTP 主机" Style="{StaticResource LabelText}"/><TextBox x:Name="SmtpHostBox" Margin="0,4,0,0"/></StackPanel>
                        <StackPanel Grid.Column="2"><TextBlock Text="端口" Style="{StaticResource LabelText}"/><TextBox x:Name="SmtpPortBox" Margin="0,4,0,0"/></StackPanel>
                    </Grid>
                    <CheckBox x:Name="SmtpSslBox" Content="SMTP 使用 SSL / TLS 或 STARTTLS" Margin="0,8,0,0" IsChecked="True"/>
                    <TextBlock x:Name="StatusText" Foreground="{DynamicResource Muted}" Margin="0,12,0,0" TextWrapping="Wrap"/>
                </StackPanel></Border>
            </StackPanel>
        </ScrollViewer>
        <Grid Grid.Row="2" Margin="0,14,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <Button x:Name="DeleteButton" Content="删除账号" Style="{StaticResource DangerButton}" Click="Delete_Click"/>
            <Button Grid.Column="2" Content="取消" Style="{StaticResource SecondaryButton}" Click="Cancel_Click"/>
            <Button Grid.Column="4" x:Name="SaveButton" Content="测试连接并保存" Style="{StaticResource PrimaryButton}" Click="Save_Click"/>
        </Grid>
    </Grid>
</Window>
