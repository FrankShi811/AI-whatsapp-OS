<Window x:Class="WAFlow.Desktop.Windows.AiConversationAssistantWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Sales OS · AI 会话助理" Width="980" Height="760" MinWidth="800" MinHeight="620"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" ShowInTaskbar="False"
        Icon="/AISalesOS;component/Assets/AI-Sales-OS.ico">
    <Grid Background="{DynamicResource Canvas}">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

        <Border Background="{DynamicResource SurfaceElevated}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="26,19">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="AI CONVERSATION COPILOT" Style="{StaticResource PageEyebrow}"/>
                    <TextBlock Text="回复客户，并把需求沉淀为销售数据" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                    <TextBlock Text="AI 只引用客户白色气泡中的原话；发送和字段写入前由你确认。" Foreground="{DynamicResource Muted}" Margin="0,5,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                    <Border Background="{DynamicResource AiSoft}" CornerRadius="14" Padding="12,7">
                        <TextBlock x:Name="ModelText" Foreground="{DynamicResource AiAccentDeep}" FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock x:Name="ConfidenceText" HorizontalAlignment="Right" Foreground="{DynamicResource Muted}" Margin="0,6,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="26,20,26,18">
                <Border Style="{StaticResource AiCard}" Padding="18" Margin="0,0,0,14">
                    <StackPanel>
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="AI 回复草稿" FontSize="17" FontWeight="SemiBold"/>
                                <TextBlock Text="可直接修改；回复语言会跟随客户最近使用的语言。" Foreground="{DynamicResource Muted}" FontSize="10.5" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" Background="{DynamicResource PrimarySurface}" CornerRadius="12" Padding="10,5">
                                <TextBlock x:Name="LanguageText" Foreground="{DynamicResource Primary}" FontWeight="SemiBold"/>
                            </Border>
                        </Grid>
                        <TextBox x:Name="ReplyBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="118" MaxHeight="220" VerticalScrollBarVisibility="Auto" Margin="0,12,0,0"/>
                    </StackPanel>
                </Border>

                <Grid Margin="0,0,0,14"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Style="{StaticResource Card}" Padding="17">
                        <StackPanel>
                            <TextBlock Text="客户需求总结" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock x:Name="NeedsSummaryText" TextWrapping="Wrap" Margin="0,9,0,0"/>
                            <TextBlock Text="意向判断" Style="{StaticResource LabelText}" Margin="0,14,0,0"/>
                            <TextBlock x:Name="IntentText" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource Card}" Padding="17">
                        <StackPanel>
                            <TextBlock Text="采购信号与风险" FontSize="16" FontWeight="SemiBold"/>
                            <TextBlock Text="采购信号" Foreground="{DynamicResource Success}" FontWeight="SemiBold" Margin="0,9,0,0"/>
                            <TextBlock x:Name="SignalsText" TextWrapping="Wrap" Margin="0,3,0,0"/>
                            <TextBlock Text="风险提醒" Foreground="{DynamicResource Warning}" FontWeight="SemiBold" Margin="0,12,0,0"/>
                            <TextBlock x:Name="RisksText" TextWrapping="Wrap" Margin="0,3,0,0"/>
                            <TextBlock Text="建议下一步" Style="{StaticResource LabelText}" Margin="0,12,0,0"/>
                            <TextBlock x:Name="NextActionText" TextWrapping="Wrap" Margin="0,3,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <Border Style="{StaticResource Card}" Padding="0">
                    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                        <Border Padding="17,14" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1">
                            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="建议同步到客户资料" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Text="只有勾选的字段才会写入；每一项都显示客户原话证据。" Foreground="{DynamicResource Muted}" FontSize="10.5" Margin="0,3,0,0"/>
                                </StackPanel>
                                <TextBlock x:Name="ProposalCountText" Grid.Column="1" Foreground="{DynamicResource AiAccentDeep}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <Border x:Name="EmptyProposalPanel" Grid.Row="1" Background="{DynamicResource PrimarySurface}" CornerRadius="10" Padding="13,10" Margin="16" Visibility="Collapsed">
                            <TextBlock Text="客户原话尚不足以安全更新具体字段。本次仍可保存 AI 需求摘要、意向、风险和建议动作。" Foreground="{DynamicResource Primary}" TextWrapping="Wrap"/>
                        </Border>
                        <DataGrid x:Name="ProposalGrid" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="False" HeadersVisibility="Column" MinHeight="150" MaxHeight="260" SelectionMode="Extended">
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="同步" Width="58"><DataGridTemplateColumn.CellTemplate><DataTemplate><CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                <DataGridTextColumn Header="客户维度" Binding="{Binding FieldLabel}" Width="145" IsReadOnly="True"/>
                                <DataGridTextColumn Header="当前值" Binding="{Binding CurrentValue}" Width="150" IsReadOnly="True"/>
                                <DataGridTextColumn Header="AI 建议值" Binding="{Binding ProposedValue}" Width="180" IsReadOnly="True"/>
                                <DataGridTextColumn Header="客户原话证据" Binding="{Binding EvidenceQuote}" Width="*" IsReadOnly="True"/>
                                <DataGridTextColumn Header="提取原因" Binding="{Binding Reason}" Width="190" IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{DynamicResource SurfaceElevated}" BorderBrush="{DynamicResource Line}" BorderThickness="0,1,0,0" Padding="22,13">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock x:Name="SendHintText" Foreground="{DynamicResource Muted}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="取消" Style="{StaticResource GhostButton}" IsCancel="True" MinWidth="82"/>
                    <Button Content="只填入回复框" Style="{StaticResource SecondaryButton}" Click="FillComposer_Click" Margin="8,0,0,0" MinWidth="128"/>
                    <Button x:Name="SendAndSyncButton" Content="发送并同步客户资料" Style="{StaticResource PrimaryButton}" Click="SendAndSync_Click" Margin="8,0,0,0" MinWidth="172"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
