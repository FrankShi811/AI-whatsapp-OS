<Window x:Class="WAFlow.Desktop.Windows.CustomerEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Sales OS · 编辑客户" Icon="/AISalesOS;component/Assets/AI-Sales-OS.ico"
        Width="980" Height="760" MinWidth="820" MinHeight="620"
        WindowStartupLocation="CenterOwner" WindowStyle="SingleBorderWindow" ResizeMode="CanResize"
        Loaded="Window_Loaded">
    <Grid Background="{DynamicResource Canvas}">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>

        <Border Background="{DynamicResource SurfaceElevated}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="24,18">
            <StackPanel>
                <TextBlock Text="编辑客户全部资料" FontSize="22" FontWeight="Bold"/>
                <TextBlock Text="系统字段用于搜索、评分和 WhatsApp；原表维度逐列保留，可逐项修改。" Foreground="{DynamicResource Muted}" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20">
            <StackPanel>
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <TextBlock Text="系统字段" Style="{StaticResource SectionTitle}" Margin="0,0,0,14"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110"/><ColumnDefinition Width="*"/><ColumnDefinition Width="24"/><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="客户名称" Style="{StaticResource LabelText}" VerticalAlignment="Center"/><TextBox x:Name="NameBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,10"/>
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="公司" Style="{StaticResource LabelText}" VerticalAlignment="Center"/><TextBox x:Name="CompanyBox" Grid.Row="0" Grid.Column="4" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="1" Text="国家 / 地区" Style="{StaticResource LabelText}" VerticalAlignment="Center"/><TextBox x:Name="CountryBox" Grid.Row="1" Grid.Column="1" Margin="0,0,0,10"/>
                            <TextBlock Grid.Row="1" Grid.Column="3" Text="WhatsApp" Style="{StaticResource LabelText}" VerticalAlignment="Center"/><TextBox x:Name="PhoneBox" Grid.Row="1" Grid.Column="4" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="2" Text="邮箱" Style="{StaticResource LabelText}" VerticalAlignment="Center"/><TextBox x:Name="EmailBox" Grid.Row="2" Grid.Column="1" Margin="0,0,0,10"/>
                            <TextBlock Grid.Row="2" Grid.Column="3" Text="负责人" Style="{StaticResource LabelText}" VerticalAlignment="Center"/><TextBox x:Name="OwnerBox" Grid.Row="2" Grid.Column="4" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="3" Text="销售语言" Style="{StaticResource LabelText}" VerticalAlignment="Center"/><TextBox x:Name="LanguageBox" Grid.Row="3" Grid.Column="1" Margin="0,0,0,10"/>
                            <TextBlock Grid.Row="3" Grid.Column="3" Text="商机阶段" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="3" Grid.Column="4" Margin="0,0,0,10">
                                <ComboBox x:Name="StageBox" DisplayMemberPath="Label"/>
                                <CheckBox x:Name="StageLockCheck" Content="阶段已人工锁定（AI 不再覆盖）" Margin="2,7,0,0"
                                          Foreground="{DynamicResource Muted}" ToolTip="取消勾选后，未来 AI 分析可再次更新该客户阶段。"/>
                            </StackPanel>

                            <TextBlock Grid.Row="4" Text="意向产品" Style="{StaticResource LabelText}" VerticalAlignment="Center"/><TextBox x:Name="ProductBox" Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="4" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="5" Text="预计订单额" Style="{StaticResource LabelText}" VerticalAlignment="Center"/><TextBox x:Name="AmountBox" Grid.Row="5" Grid.Column="1" Margin="0,0,0,10"/>
                            <TextBlock Grid.Row="5" Grid.Column="3" Text="币种" Style="{StaticResource LabelText}" VerticalAlignment="Center"/><TextBox x:Name="CurrencyBox" Grid.Row="5" Grid.Column="4" Margin="0,0,0,10"/>

                            <TextBlock Grid.Row="6" Text="来源" Style="{StaticResource LabelText}" VerticalAlignment="Center"/><TextBox x:Name="SourceBox" Grid.Row="6" Grid.Column="1" Margin="0,0,0,10"/>
                            <TextBlock Grid.Row="6" Grid.Column="3" Text="标签" Style="{StaticResource LabelText}" VerticalAlignment="Center"/><TextBox x:Name="TagsBox" Grid.Row="6" Grid.Column="4" Margin="0,0,0,10" ToolTip="用逗号、分号或竖线分隔"/>

                            <TextBlock Grid.Row="7" Text="联系权限" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="4" Orientation="Horizontal">
                                <CheckBox x:Name="OptInCheck" Content="已同意 WhatsApp 营销联系" Margin="0,0,28,0" VerticalAlignment="Center"/>
                                <CheckBox x:Name="OptedOutCheck" Content="已退订" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock Text="备注 / 最新沟通" Style="{StaticResource LabelText}" Margin="0,15,0,5"/>
                        <TextBox x:Name="NotesBox" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="82" VerticalContentAlignment="Top"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="AI 商机评分卡" Style="{StaticResource SectionTitle}"/>
                                <TextBlock x:Name="AiScoreStateText" Text="等待 Lead Intelligence V2 分析" Foreground="{StaticResource Muted}" Margin="0,5,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                <StackPanel Margin="0,0,12,0"><TextBlock Text="AI Score" Foreground="{StaticResource Muted}" FontSize="10" HorizontalAlignment="Right"/><TextBlock x:Name="AiScoreText" Text="0" FontSize="28" FontWeight="Bold" HorizontalAlignment="Right"/></StackPanel>
                                <Border Background="{StaticResource SuccessSoft}" CornerRadius="20" Width="54" Height="54"><TextBlock x:Name="AiGradeText" Text="D级" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,16,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="150"/><ColumnDefinition Width="150"/><ColumnDefinition Width="150"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="基础画像分" Style="{StaticResource LabelText}"/><TextBlock x:Name="AiBaseScoreText" Text="0 / 100" FontWeight="SemiBold" Margin="0,4,0,0"/></StackPanel>
                            <StackPanel Grid.Column="1"><TextBlock Text="行为修正" Style="{StaticResource LabelText}"/><TextBlock x:Name="AiBehaviorScoreText" Text="0 / ±20" FontWeight="SemiBold" Margin="0,4,0,0"/></StackPanel>
                            <StackPanel Grid.Column="2"><TextBlock Text="购买概率" Style="{StaticResource LabelText}"/><TextBlock x:Name="AiPurchaseProbabilityText" Text="0%" FontWeight="SemiBold" Margin="0,4,0,0"/></StackPanel>
                            <StackPanel Grid.Column="3"><TextBlock Text="下一步" Style="{StaticResource LabelText}"/><TextBlock x:Name="AiNextActionText" Text="等待分析" TextWrapping="Wrap" Margin="0,4,0,0"/></StackPanel>
                        </Grid>
                        <TextBlock Text="评分原因与证据" Style="{StaticResource LabelText}" Margin="0,16,0,5"/>
                        <ItemsControl x:Name="AiReasonItems"><ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding StringFormat=• {0}}" TextWrapping="Wrap" Margin="0,2,0,0"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                        <TextBlock Text="风险" Style="{StaticResource LabelText}" Margin="0,14,0,4"/>
                        <TextBlock x:Name="AiRiskText" Text="尚未分析" Foreground="#8A4E29" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Customer 360 · 个人 AI 销售员工" Style="{StaticResource SectionTitle}"/>
                                <TextBlock x:Name="BrainStatusText" Text="正在整合客户上下文…" Foreground="{StaticResource Muted}" Margin="0,5,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button x:Name="RefreshBrainButton" Content="刷新数据" Style="{StaticResource SecondaryButton}" Click="RefreshBrain_Click" Margin="0,0,8,0"/>
                                <Button x:Name="AnalyzeBrainButton" Content="AI 分析并生成行动" Style="{StaticResource PrimaryButton}" Click="AnalyzeBrain_Click"/>
                            </StackPanel>
                        </Grid>

                        <UniformGrid Columns="4" Margin="0,16,0,0">
                            <Border Background="#F8FBF9" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                                <StackPanel><TextBlock Text="购买概率" Style="{StaticResource LabelText}"/><TextBlock x:Name="BrainProbabilityText" Text="0%" FontSize="21" FontWeight="Bold" Margin="0,4,0,0"/></StackPanel>
                            </Border>
                            <Border Background="#F8FBF9" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                                <StackPanel><TextBlock Text="AI 置信度" Style="{StaticResource LabelText}"/><TextBlock x:Name="BrainConfidenceText" Text="0%" FontSize="21" FontWeight="Bold" Margin="0,4,0,0"/></StackPanel>
                            </Border>
                            <Border Background="#F8FBF9" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                                <StackPanel><TextBlock Text="数据覆盖" Style="{StaticResource LabelText}"/><TextBlock x:Name="BrainCoverageText" Text="0%" FontSize="21" FontWeight="Bold" Margin="0,4,0,0"/></StackPanel>
                            </Border>
                            <Border Background="#F8FBF9" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="12">
                                <StackPanel><TextBlock Text="建议阶段" Style="{StaticResource LabelText}"/><TextBlock x:Name="BrainStageText" Text="待分析" FontSize="18" FontWeight="Bold" Margin="0,5,0,0"/></StackPanel>
                            </Border>
                        </UniformGrid>

                        <TextBlock Text="客户理解" Style="{StaticResource LabelText}" Margin="0,16,0,5"/>
                        <TextBlock x:Name="BrainSummaryText" Text="等待 Customer Brain 整合 CRM、WhatsApp、邮件、触达和历史分析。" TextWrapping="Wrap"/>
                        <Border Background="{StaticResource SuccessSoft}" CornerRadius="8" Padding="12" Margin="0,14,0,0">
                            <StackPanel>
                                <TextBlock Text="下一步最佳行动" Style="{StaticResource LabelText}"/>
                                <TextBlock x:Name="BrainNextActionText" Text="等待分析" TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{StaticResource AiSoft}" BorderBrush="{StaticResource AiLine}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="真实结果与个人经验" Style="{StaticResource LabelText}"/>
                                <TextBlock x:Name="BrainLearningMetricsText" Text="尚无已执行行动的真实结果" TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,5,0,0"/>
                                <TextBlock x:Name="BrainLearningStrategyText" Text="执行建议后，系统会根据真实回复、阶段推进和成交结果持续总结个人经验。" TextWrapping="Wrap" Foreground="{StaticResource Muted}" Margin="0,5,0,0"/>
                                <TextBlock x:Name="BrainTalkTrackText" Text="高表现话术：等待真实样本" TextWrapping="Wrap" Foreground="{StaticResource Muted}" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,16,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="AI 建议历史" Style="{StaticResource LabelText}" Margin="0,0,0,5"/>
                                <ListBox x:Name="BrainRecommendationItems" DisplayMemberPath="DisplayText" MinHeight="70" MaxHeight="150"/>
                                <WrapPanel Margin="0,7,0,0">
                                    <Button Content="接受" Tag="accept" Click="RecommendationAction_Click" Style="{StaticResource GhostButton}" Margin="0,0,5,5"/>
                                    <Button Content="延期 24h" Tag="defer" Click="RecommendationAction_Click" Style="{StaticResource GhostButton}" Margin="0,0,5,5"/>
                                    <Button Content="开始" Tag="start" Click="RecommendationAction_Click" Style="{StaticResource GhostButton}" Margin="0,0,5,5"/>
                                    <Button Content="完成" Tag="complete" Click="RecommendationAction_Click" Style="{StaticResource GhostButton}" Margin="0,0,5,5"/>
                                    <Button Content="失败" Tag="fail" Click="RecommendationAction_Click" Style="{StaticResource GhostButton}" Margin="0,0,5,5"/>
                                    <Button Content="忽略" Tag="dismiss" Click="RecommendationAction_Click" Style="{StaticResource GhostButton}" Margin="0,0,5,5"/>
                                </WrapPanel>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="待办任务" Style="{StaticResource LabelText}" Margin="0,0,0,5"/>
                                <ItemsControl x:Name="BrainTaskItems"><ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding StringFormat=• {0}}" TextWrapping="Wrap" Margin="0,2,0,4"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="最近客户轨迹" Style="{StaticResource LabelText}" Margin="0,0,0,5"/>
                                <ItemsControl x:Name="BrainEventItems"><ItemsControl.ItemTemplate><DataTemplate><TextBlock Text="{Binding StringFormat=• {0}}" TextWrapping="Wrap" Margin="0,2,0,4"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,16,0,0">
                    <StackPanel>
                        <TextBlock Text="原表全部维度" Style="{StaticResource SectionTitle}"/>
                        <TextBlock Text="这里按上传表格的原始列名逐项显示。修改后保存，客户列表中的对应单元格会同步更新。" Foreground="{StaticResource Muted}" Margin="0,5,0,14"/>
                        <ItemsControl x:Name="OriginalDimensions">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,9">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="270"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Header}" ToolTip="{Binding Header}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" Margin="0,0,16,0"/>
                                        <TextBox Grid.Column="1" Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Background="#F8FBF9" BorderBrush="{StaticResource Line}" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,8,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                <TextBox x:Name="NewDimensionNameBox" ToolTip="新维度名称" Margin="0,0,8,0"/>
                                <TextBox x:Name="NewDimensionValueBox" Grid.Column="1" ToolTip="新维度值" Margin="0,0,8,0"/>
                                <Button Grid.Column="2" Content="新增维度" Style="{StaticResource SecondaryButton}" Click="AddDimension_Click"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="24,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="DeleteButton" Content="&#x5220;&#x9664;&#x8BE5;&#x5BA2;&#x6237;" Click="Delete_Click" Margin="0,0,18,0" Padding="18,9" Background="#FEECEC" Foreground="#B42318" BorderBrush="#F4B8B3"/>
                <Button Content="取消" IsCancel="True" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                <Button x:Name="SaveButton" Content="保存并同步" Style="{StaticResource PrimaryButton}" Click="Save_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
