<Window x:Class="WAFlow.Desktop.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:WAFlow.Desktop.Controls"
        Title="AI Sales OS · API 与体验设置" Icon="/AISalesOS;component/Assets/AI-Sales-OS.ico"
        Width="820" Height="680" MinWidth="700" MinHeight="520"
        WindowStartupLocation="CenterOwner" WindowStyle="SingleBorderWindow" ResizeMode="CanResize">
    <Grid Background="{DynamicResource Canvas}">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Background="{DynamicResource SurfaceElevated}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="28,22">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel><TextBlock Text="SYSTEM CONFIGURATION" Style="{StaticResource PageEyebrow}"/><TextBlock x:Name="SettingsTitleText" Text="API 与体验设置" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/><TextBlock x:Name="SettingsSubtitleText" Text="连接兼容 AI Provider、选择工作模型，并管理桌面体验。" Foreground="{DynamicResource Muted}" Margin="0,6,0,0"/></StackPanel>
                <Button Grid.Column="1" Content="本页使用手册" ToolTip="查看 API 对接的功能介绍和操作步骤" Style="{StaticResource SecondaryButton}" Click="ShowGuide_Click" VerticalAlignment="Top"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="28,22,28,28">
                <Border Style="{StaticResource AiCard}">
                    <StackPanel>
                        <Grid><StackPanel><TextBlock Text="AI Provider" Style="{StaticResource SectionTitle}"/><TextBlock Text="DeepSeek / OpenAI 兼容接口" Style="{StaticResource LabelText}" Margin="0,3,0,0"/></StackPanel><Border HorizontalAlignment="Right" Background="{DynamicResource SuccessSoft}" CornerRadius="10" Padding="9,5"><TextBlock x:Name="ApiStatusText" Text="未配置" Foreground="{DynamicResource Success}" FontSize="10.5" FontWeight="SemiBold"/></Border></Grid>
                        <Border Background="{DynamicResource SurfaceElevated}" BorderBrush="{DynamicResource AiSoft}" BorderThickness="1" CornerRadius="11" Padding="15" Margin="0,16,0,0">
                            <StackPanel>
                                <TextBlock Text="API Key" Style="{StaticResource LabelText}"/><PasswordBox x:Name="ApiKeyBox" Margin="0,5,0,0" PasswordChanged="ProviderInput_Changed"/>
                                <TextBlock Text="留空会保留现有 Key；凭据只写入 Windows 凭据管理器。" Foreground="{DynamicResource Muted}" FontSize="9.5" Margin="0,5,0,0"/>
                                <Grid Margin="0,13,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="1.1*"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,8,0"><TextBlock Text="Base URL" Style="{StaticResource LabelText}"/><TextBox x:Name="BaseUrlBox" Text="https://api.deepseek.com" Margin="0,5,0,0" TextChanged="ProviderInput_Changed"/></StackPanel>
                                    <StackPanel Grid.Column="1" Margin="8,0,0,0"><TextBlock Text="工作模型" Style="{StaticResource LabelText}"/><Grid Margin="0,5,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><ComboBox x:Name="ModelBox" IsEditable="False" IsTextSearchEnabled="True" MinWidth="190" ToolTip="从 Provider 的 /models 接口自动拉取"/><Button x:Name="ReloadModelsButton" Grid.Column="1" Content="↻ 拉取" Style="{StaticResource SecondaryButton}" Padding="11,7" Margin="8,0,0,0" Click="ReloadModels_Click"/></Grid></StackPanel>
                                </Grid>
                                <TextBlock x:Name="ModelStatusText" Text="填写 API Key 后将自动拉取可用模型。" Foreground="{DynamicResource Muted}" FontSize="9.5" Margin="0,8,0,0" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                        <Border Background="{DynamicResource WarningSoft}" CornerRadius="9" Padding="11" Margin="0,12,0,0"><TextBlock Text="AI 分析只在结构校验成功后更新商机分数与 Dashboard；失败客户继续保持 D / 0 并进入重试。" Foreground="{DynamicResource Warning}" FontSize="9.5" TextWrapping="Wrap"/></Border>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,15,0,0">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="230"/></Grid.ColumnDefinitions>
                        <StackPanel><TextBlock Text="外观与可读性" Style="{StaticResource SectionTitle}"/><TextBlock Text="跟随系统、浅色或深色；所有页面共用同一套语义颜色。" Foreground="{DynamicResource Muted}" FontSize="10.5" Margin="0,5,20,0" TextWrapping="Wrap"/></StackPanel>
                        <StackPanel Grid.Column="1"><TextBlock Text="主题模式" Style="{StaticResource LabelText}"/><ComboBox x:Name="ThemeModeBox" Margin="0,5,0,0"/></StackPanel>
                    </Grid>
                </Border>

                <Border Style="{StaticResource Card}" Margin="0,15,0,0">
                    <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="42"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <Border Width="36" Height="36" Background="{DynamicResource PrimarySoft}" CornerRadius="10"><TextBlock Text="▣" Foreground="{DynamicResource Primary}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="15"/></Border>
                        <StackPanel Grid.Column="1"><TextBlock Text="本地数据工作区" Style="{StaticResource SectionTitle}"/><TextBlock x:Name="DatabasePathText" Foreground="{DynamicResource Muted}" FontSize="10" Margin="0,5,0,0" TextWrapping="Wrap"/><TextBlock Text="客户、AI 结果、会话索引和自动化审计均保存在本机。" Foreground="{DynamicResource Muted}" FontSize="9.5" Margin="0,4,0,0"/></StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Background="{DynamicResource SurfaceElevated}" BorderBrush="{DynamicResource Line}" BorderThickness="0,1,0,0" Padding="28,15">
            <Grid><TextBlock Text="更改保存后立即生效" Foreground="{DynamicResource Muted}" FontSize="9.5" VerticalAlignment="Center"/><StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="取消" IsCancel="True" Style="{StaticResource SecondaryButton}" Click="Cancel_Click" Margin="0,0,8,0"/><Button x:Name="SaveButton" Content="保存并应用" Style="{StaticResource PrimaryButton}" Click="Save_Click"/></StackPanel></Grid>
        </Border>

        <controls:GuideOverlay x:Name="SettingsGuide" Grid.RowSpan="3" Panel.ZIndex="100"/>
    </Grid>
</Window>
