<Window x:Class="WAFlow.Desktop.Windows.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Sales OS · 企业与 DeepSeek 设置" Icon="/AISalesOS;component/Assets/AI-Sales-OS.ico" Width="760" Height="680" MinWidth="680" MinHeight="620" WindowStartupLocation="CenterOwner" WindowStyle="SingleBorderWindow" ResizeMode="CanResize">
    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Background="White" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="24,18">
            <StackPanel><TextBlock Text="企业销售资料与 DeepSeek" FontSize="22" FontWeight="Bold"/><TextBlock Text="资料会叠加到客户字段用于分析；API Key 只写入 Windows 凭据管理器。" Foreground="{StaticResource Muted}" Margin="0,5,0,0"/></StackPanel>
        </Border>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"><StackPanel Margin="24">
            <Border Style="{StaticResource Card}"><StackPanel>
                <TextBlock Text="企业销售资料" Style="{StaticResource SectionTitle}"/>
                <TextBlock Text="企业名称 *" Style="{StaticResource LabelText}" Margin="0,14,0,5"/><TextBox x:Name="CompanyNameBox"/>
                <TextBlock Text="主营产品 *（每行一个）" Style="{StaticResource LabelText}" Margin="0,12,0,5"/><TextBox x:Name="ProductsBox" Height="88" AcceptsReturn="True" VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto"/>
                <TextBlock Text="企业优势 *（每行一个）" Style="{StaticResource LabelText}" Margin="0,12,0,5"/><TextBox x:Name="AdvantagesBox" Height="88" AcceptsReturn="True" VerticalContentAlignment="Top" VerticalScrollBarVisibility="Auto"/>
                <Grid Margin="0,12,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,8,0"><TextBlock Text="默认销售语言" Style="{StaticResource LabelText}" Margin="0,0,0,5"/><TextBox x:Name="LanguageBox" Text="en"/></StackPanel>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0"><TextBlock Text="目标市场（逗号分隔）" Style="{StaticResource LabelText}" Margin="0,0,0,5"/><TextBox x:Name="MarketsBox"/></StackPanel>
                </Grid>
            </StackPanel></Border>
            <Border Style="{StaticResource Card}" Margin="0,16,0,0"><StackPanel>
                <Grid><TextBlock Text="DeepSeek Provider" Style="{StaticResource SectionTitle}"/><Border HorizontalAlignment="Right" Background="{StaticResource SuccessSoft}" CornerRadius="10" Padding="9,4"><TextBlock x:Name="ApiStatusText" Text="未配置" Foreground="#0B7855" FontSize="11"/></Border></Grid>
                <TextBlock Text="API Key" Style="{StaticResource LabelText}" Margin="0,14,0,5"/><PasswordBox x:Name="ApiKeyBox" Padding="10,8" BorderBrush="#CED9D3" BorderThickness="1" FontSize="13"/>
                <TextBlock Text="留空会保留现有 Key；程序不会将 Key 写入数据库、日志或界面。" Foreground="{StaticResource Muted}" FontSize="10" Margin="0,5,0,0"/>
                <Grid Margin="0,12,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="1.5*"/><ColumnDefinition/></Grid.ColumnDefinitions>
                    <StackPanel Margin="0,0,8,0"><TextBlock Text="Base URL" Style="{StaticResource LabelText}" Margin="0,0,0,5"/><TextBox x:Name="BaseUrlBox" Text="https://api.deepseek.com"/></StackPanel>
                    <StackPanel Grid.Column="1" Margin="8,0,0,0"><TextBlock Text="模型" Style="{StaticResource LabelText}" Margin="0,0,0,5"/><TextBox x:Name="ModelBox" Text="deepseek-chat"/></StackPanel>
                </Grid>
            </StackPanel></Border>
            <Border Background="#EDF4F0" CornerRadius="9" Padding="12" Margin="0,16,0,0"><StackPanel><TextBlock Text="本地数据位置" FontWeight="SemiBold" FontSize="11"/><TextBlock x:Name="DatabasePathText" Foreground="{StaticResource Muted}" FontSize="10" Margin="0,4,0,0" TextWrapping="Wrap"/></StackPanel></Border>
        </StackPanel></ScrollViewer>
        <Border Grid.Row="2" Background="White" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="24,14">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="取消" IsCancel="True" Style="{StaticResource SecondaryButton}" Click="Cancel_Click" Margin="0,0,8,0"/><Button x:Name="SaveButton" Content="保存设置" Style="{StaticResource PrimaryButton}" Click="Save_Click"/></StackPanel>
        </Border>
    </Grid>
</Window>
