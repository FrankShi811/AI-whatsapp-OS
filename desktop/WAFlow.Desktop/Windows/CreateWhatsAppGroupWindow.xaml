<Window x:Class="WAFlow.Desktop.Windows.CreateWhatsAppGroupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Sales OS · 新建 WhatsApp 群组" Width="820" Height="720" MinWidth="680" MinHeight="560"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize" ShowInTaskbar="False"
        Icon="/AISalesOS;component/Assets/AI-Sales-OS.ico">
    <Grid Background="{DynamicResource Canvas}" Margin="0">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Background="{DynamicResource SurfaceElevated}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="26,20">
            <StackPanel>
                <TextBlock Text="WHATSAPP GROUP" Style="{StaticResource PageEyebrow}"/>
                <TextBlock Text="建立 WhatsApp 群组" FontSize="24" FontWeight="Bold" Margin="0,5,0,0"/>
                <TextBlock Text="选择已同步联系人，创建结果会同步到当前手机 WhatsApp 账号。" Foreground="{DynamicResource Muted}" Margin="0,5,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="26,20,26,16">
            <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                <TextBlock Text="群名称" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                <TextBox x:Name="SubjectBox" Grid.Column="1" MaxLength="100" ToolTip="1–100 个字符" TextChanged="SubjectBox_TextChanged"/>
            </Grid>
            <Grid Grid.Row="1" Margin="0,14,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBlock Text="添加号码" Style="{StaticResource LabelText}" VerticalAlignment="Center"/>
                <TextBox x:Name="ManualPhoneBox" Grid.Column="1" ToolTip="输入带国家区号的 WhatsApp 号码，例如 +447700900123"/>
                <Button Grid.Column="2" Content="添加成员" Style="{StaticResource SecondaryButton}" Click="AddManualMember_Click" Margin="8,0,0,0"/>
            </Grid>
            <Grid Grid.Row="2" Margin="0,14,0,10"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <TextBox x:Name="SearchBox" ToolTip="搜索联系人姓名或号码" TextChanged="SearchBox_TextChanged"/>
                <TextBlock x:Name="SelectionText" Grid.Column="1" Text="已选 0 位" Foreground="{DynamicResource AiAccentDeep}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="14,0"/>
                <Button Grid.Column="2" Content="清除选择" Style="{StaticResource GhostButton}" Click="ClearSelection_Click" Padding="10,6"/>
            </Grid>
            <Border Grid.Row="3" Background="{DynamicResource Surface}" BorderBrush="{DynamicResource Line}" BorderThickness="1" CornerRadius="12" Padding="1">
                <DataGrid x:Name="MemberGrid" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="False" SelectionMode="Extended" HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="选择" Width="54"><DataGridTemplateColumn.CellTemplate><DataTemplate><CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" Click="MemberCheck_Click"/></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                        <DataGridTextColumn Header="联系人" Binding="{Binding DisplayName}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="WhatsApp 号码" Binding="{Binding Phone}" Width="190" IsReadOnly="True"/>
                        <DataGridTextColumn Header="来源" Binding="{Binding SourceLabel}" Width="120" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
            <Border Grid.Row="4" Background="{DynamicResource WarningSoft}" CornerRadius="10" Padding="12,9" Margin="0,12,0,0">
                <TextBlock Foreground="{DynamicResource Warning}" FontSize="10.5" TextWrapping="Wrap" Text="提示：这是个人 WhatsApp 账号的非官方连接能力。建群会真实写入手机端；请只添加认识且同意入群的联系人，避免短时间大量建群导致账号受限。"/>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{DynamicResource SurfaceElevated}" BorderBrush="{DynamicResource Line}" BorderThickness="0,1,0,0" Padding="22,13">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Style="{StaticResource SecondaryButton}" IsCancel="True" MinWidth="92"/>
                <Button x:Name="CreateButton" Content="确认并建立群组" Style="{StaticResource PrimaryButton}" Click="Create_Click" Margin="10,0,0,0" MinWidth="140" IsEnabled="False"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
