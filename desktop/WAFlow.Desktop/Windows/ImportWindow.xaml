<Window x:Class="WAFlow.Desktop.Windows.ImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Sales OS · 导入商机" Icon="/AISalesOS;component/Assets/AI-Sales-OS.ico" Width="1060" Height="700" MinWidth="900" MinHeight="620" WindowStartupLocation="CenterOwner" WindowStyle="SingleBorderWindow" ResizeMode="CanResize">
    <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
        <Border Background="White" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1" Padding="24,18">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <StackPanel><TextBlock Text="导入 Excel / CSV 商机" FontSize="22" FontWeight="Bold"/><TextBlock Text="上传 → 字段映射 → 重复差异预览 → 分批提交" Foreground="{StaticResource Muted}" Margin="0,5,0,0"/></StackPanel>
                <TextBlock Grid.Column="1" Text="单文件 200MB · 不设固定行数上限" Foreground="{StaticResource Muted}" VerticalAlignment="Center"/>
            </Grid>
        </Border>
        <Grid Grid.Row="1" Margin="24,16,24,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal"><Border x:Name="Step1Circle" Width="28" Height="28" CornerRadius="14" Background="{StaticResource Primary}"><TextBlock Text="1" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/></Border><TextBlock Text="选择文件" VerticalAlignment="Center" Margin="8,0" FontWeight="SemiBold"/></StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"><Border x:Name="Step2Circle" Width="28" Height="28" CornerRadius="14" Background="#CBD7D1"><TextBlock Text="2" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/></Border><TextBlock Text="字段映射" VerticalAlignment="Center" Margin="8,0" FontWeight="SemiBold"/></StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right"><Border x:Name="Step3Circle" Width="28" Height="28" CornerRadius="14" Background="#CBD7D1"><TextBlock Text="3" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/></Border><TextBlock Text="预览与提交" VerticalAlignment="Center" Margin="8,0" FontWeight="SemiBold"/></StackPanel>
        </Grid>
        <Grid Grid.Row="2" Margin="24,16,24,16">
            <Border x:Name="SelectPanel" Style="{StaticResource Card}">
                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <StackPanel><TextBlock Text="选择本地文件" Style="{StaticResource SectionTitle}"/><TextBlock Text="支持 .xlsx、UTF-8 / GB18030 CSV；数万行会在后台解析并分批写入。" Foreground="{StaticResource Muted}" Margin="0,5,0,0"/></StackPanel>
                    <Border Grid.Row="1" BorderBrush="#BFD3CA" BorderThickness="1" CornerRadius="12" Background="#F8FBF9" Margin="0,20,0,0">
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"><TextBlock Text="▣" FontSize="42" Foreground="{StaticResource Primary}" HorizontalAlignment="Center"/><TextBlock Text="选择 Excel 或 CSV 商机表" FontSize="17" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,12,0,0"/><TextBlock Text="文件只在本机 EXE 进程内解析，不会上传到云端服务器。" Foreground="{StaticResource Muted}" HorizontalAlignment="Center" Margin="0,6,0,14"/><Button Content="浏览文件…" Style="{StaticResource PrimaryButton}" Click="Browse_Click" HorizontalAlignment="Center"/><TextBlock x:Name="FilePathText" Foreground="{StaticResource Muted}" Margin="0,14,0,0" MaxWidth="680" TextTrimming="CharacterEllipsis"/></StackPanel>
                    </Border>
                </Grid>
            </Border>
            <Border x:Name="MappingPanel" Style="{StaticResource Card}" Visibility="Collapsed" Padding="0">
                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <Border Padding="18,14" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="260"/></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="校正字段映射" Style="{StaticResource SectionTitle}"/><TextBlock x:Name="MappingHintText" Foreground="{StaticResource Muted}" Margin="0,4,0,0"/><TextBlock Text="未识别表头默认保留为自定义维度，不会丢列；不需要的列可手动选择“不导入”。" Foreground="{StaticResource Primary}" FontSize="11" Margin="0,3,0,0"/></StackPanel>
                            <ComboBox x:Name="SheetCombo" Grid.Column="1" SelectionChanged="SheetCombo_SelectionChanged" DisplayMemberPath="Name"/>
                        </Grid>
                    </Border>
                    <DataGrid x:Name="MappingGrid" Grid.Row="1" CanUserAddRows="False" Margin="16" SelectionUnit="Cell">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="原始表头" Binding="{Binding Header}" Width="1.2*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="样例值" Binding="{Binding Sample}" Width="1.5*" IsReadOnly="True"/>
                            <DataGridComboBoxColumn x:Name="TargetColumn" Header="AI Sales OS 字段" SelectedValueBinding="{Binding Target, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Value" DisplayMemberPath="Label" Width="1.1*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
            <Border x:Name="PreviewPanel" Style="{StaticResource Card}" Visibility="Collapsed" Padding="0">
                <Grid><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Border Padding="18,14" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <StackPanel><TextBlock Text="重复差异与风险预览" Style="{StaticResource SectionTitle}"/><TextBlock Text="重复记录默认仅用非空导入值更新已映射字段；不会删除历史。" Foreground="{StaticResource Muted}" Margin="0,4,0,0"/></StackPanel>
                            <TextBlock x:Name="PreviewStatsText" Grid.Column="1" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource Primary}"/>
                        </Grid>
                    </Border>
                    <DataGrid x:Name="PreviewGrid" Grid.Row="1" IsReadOnly="True" Margin="16">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="行" Binding="{Binding RowNumber}" Width="45"/>
                            <DataGridTextColumn Header="客户" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="公司" Binding="{Binding Company}" Width="1.2*"/>
                            <DataGridTextColumn Header="国家" Binding="{Binding Country}" Width="90"/>
                            <DataGridTextColumn Header="E.164 号码" Binding="{Binding PhoneE164}" Width="120"/>
                            <DataGridTextColumn Header="状态" Binding="{Binding StatusLabel}" Width="100"/>
                            <DataGridTextColumn Header="将更新" Binding="{Binding Changes}" Width="1.1*"/>
                            <DataGridTextColumn Header="警告 / 错误" Binding="{Binding WarningsLabel}" Width="1.4*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <Border Grid.Row="2" Background="#F8FAF9" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="16">
                        <StackPanel Orientation="Horizontal"><CheckBox x:Name="AllowStageCheck" Content="允许导入值变更重复客户阶段" VerticalAlignment="Center" Margin="0,0,24,0"/><CheckBox x:Name="AllowOwnerCheck" Content="允许导入值变更重复客户负责人" VerticalAlignment="Center"/></StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        <Border Grid.Row="3" Background="White" BorderBrush="{StaticResource Line}" BorderThickness="0,1,0,0" Padding="24,14">
            <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <Button x:Name="BackButton" Content="上一步" Style="{StaticResource SecondaryButton}" Click="Back_Click" Visibility="Collapsed" HorizontalAlignment="Left"/>
                <StackPanel x:Name="ProgressPanel" Grid.Column="1" Margin="24,0" Visibility="Collapsed"><TextBlock x:Name="ImportProgressText" Text="正在处理" Foreground="{StaticResource Muted}" FontSize="11"/><ProgressBar x:Name="ImportProgressBar" Height="5" Minimum="0" Maximum="100" Margin="0,5,0,0"/></StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="取消" IsCancel="True" Style="{StaticResource SecondaryButton}" Click="Cancel_Click" Margin="0,0,8,0"/><Button x:Name="NextButton" Content="解析并继续" Style="{StaticResource PrimaryButton}" Click="Next_Click"/></StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
