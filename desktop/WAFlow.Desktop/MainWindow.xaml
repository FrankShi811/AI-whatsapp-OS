<Window x:Class="WAFlow.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Sales OS · WhatsApp 销售智能" Width="1280" Height="720" MinWidth="1120" MinHeight="680"
        Icon="/AISalesOS;component/Assets/AI-Sales-OS.ico"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResize" Background="{StaticResource Canvas}">
    <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="226"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
        <Border Grid.Column="0" Background="{StaticResource Sidebar}">
            <Grid Margin="18,20">
                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="28"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal">
                    <Border Width="40" Height="40" Background="#F4F8FF" CornerRadius="10" Padding="4">
                        <Image Source="/AISalesOS;component/Assets/AI-Sales-OS.png" Stretch="Uniform"/>
                    </Border>
                    <StackPanel Margin="11,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="AI Sales OS" Foreground="White" FontWeight="Bold" FontSize="16"/>
                        <TextBlock Text="Lead Intelligence" Foreground="#8FB5A7" FontSize="10"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Row="2">
                    <Button x:Name="DashboardButton" Tag="dashboard" Click="Navigate_Click" Content="▦   Dashboard" Style="{StaticResource NavButton}"/>
                    <Button x:Name="IntelligenceButton" Tag="intelligence" Click="Navigate_Click" Content="✦   商机智能" Style="{StaticResource NavButton}"/>
                    <Button x:Name="CustomersButton" Tag="customers" Click="Navigate_Click" Content="◎   客户列表" Style="{StaticResource NavButton}"/>
                    <Button x:Name="InboxButton" Tag="inbox" Click="Navigate_Click" Content="◉   WhatsApp Inbox" Style="{StaticResource NavButton}"/>
                    <Button x:Name="BroadcastButton" Tag="broadcast" Click="Navigate_Click" Content="⚙   WhatsApp 自动化群发" Style="{StaticResource NavButton}"/>
                    <Border Height="1" Background="#29463B" Margin="8,16"/>
                    <Button IsEnabled="False" Content="◫   Analytics · 后续" Style="{StaticResource NavButton}" Opacity="0.5"/>
                </StackPanel>
                <Border Grid.Row="3" Background="#17372C" CornerRadius="10" Padding="12">
                    <StackPanel>
                        <TextBlock Text="●  本地原生模式" Foreground="#7BE0BE" FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="SQLite · QR Bridge · 无本地 HTTP" Foreground="#88A99D" FontSize="10" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        <Grid Grid.Column="1">
            <Grid.RowDefinitions><RowDefinition Height="68"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Background="White" BorderBrush="{StaticResource Line}" BorderThickness="0,0,0,1">
                <Grid Margin="28,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="TopTitle" Text="Dashboard" FontSize="15" FontWeight="SemiBold"/>
                        <TextBlock x:Name="TopSubtitle" Text="全球买家商机总览" Foreground="{StaticResource Muted}" FontSize="11"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="ProviderBadge" Background="{StaticResource WarningSoft}" CornerRadius="12" Padding="10,5" Margin="0,0,12,0">
                            <TextBlock x:Name="ProviderText" Text="DeepSeek 未配置" Foreground="#8A6110" FontSize="11" FontWeight="SemiBold"/>
                        </Border>
                        <Button Content="使用引导" Style="{StaticResource SecondaryButton}" Click="ShowGuide_Click" Margin="0,0,8,0"/>
                        <Button Content="企业与 AI 设置" Style="{StaticResource SecondaryButton}" Click="Settings_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
            <ContentControl x:Name="ContentHost" Grid.Row="1"/>
        </Grid>

        <Grid x:Name="OnboardingOverlay" Grid.ColumnSpan="2" Panel.ZIndex="100" Background="#C9001510" Visibility="Collapsed">
            <Border Width="660" MaxHeight="610" Background="White" BorderBrush="#CFE1D9" BorderThickness="1" CornerRadius="18" Padding="30,26" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal">
                            <Border Width="46" Height="46" Background="#F1F7F4" CornerRadius="12" Padding="5"><Image Source="/AISalesOS;component/Assets/AI-Sales-OS.png" Stretch="Uniform"/></Border>
                            <StackPanel Margin="12,0,0,0" VerticalAlignment="Center"><TextBlock Text="AI Sales OS 首次使用引导" FontWeight="Bold" FontSize="18"/><TextBlock x:Name="OnboardingStepText" Text="第 1 / 5 步" Foreground="{StaticResource Primary}" FontSize="11" Margin="0,3,0,0"/></StackPanel>
                        </StackPanel>
                        <Button Grid.Column="1" Content="稍后再看" Style="{StaticResource SecondaryButton}" Click="SkipGuide_Click" VerticalAlignment="Top"/>
                    </Grid>
                    <TextBlock Grid.Row="1" x:Name="OnboardingTitle" Text="欢迎使用 AI Sales OS" FontWeight="Bold" FontSize="25" Margin="0,25,0,0"/>
                    <TextBlock Grid.Row="2" x:Name="OnboardingBody" TextWrapping="Wrap" FontSize="14" LineHeight="23" Foreground="#314A41" Margin="0,12,0,0"/>
                    <Border Grid.Row="3" Background="#EDF6F1" BorderBrush="#D2E8DD" BorderThickness="1" CornerRadius="11" Padding="16" Margin="0,18,0,20">
                        <StackPanel>
                            <TextBlock x:Name="OnboardingTarget" FontWeight="SemiBold" Foreground="#12684F"/>
                            <TextBlock x:Name="OnboardingTips" TextWrapping="Wrap" LineHeight="21" Foreground="#48675B" Margin="0,7,0,0"/>
                            <Button x:Name="OnboardingSettingsButton" Content="现在打开企业与 AI 设置" Style="{StaticResource PrimaryButton}" Click="OnboardingSettings_Click" HorizontalAlignment="Left" Margin="0,13,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="所有客户和任务数据默认保存在本机 SQLite。" Foreground="{StaticResource Muted}" FontSize="10" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" x:Name="OnboardingBackButton" Content="上一步" Style="{StaticResource SecondaryButton}" Click="OnboardingBack_Click"/>
                        <Button Grid.Column="3" x:Name="OnboardingNextButton" Content="下一步" Style="{StaticResource PrimaryButton}" Click="OnboardingNext_Click" MinWidth="100"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
