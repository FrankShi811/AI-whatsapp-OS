<Window x:Class="WAFlow.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:WAFlow.Desktop.Controls"
        Title="AI Sales OS · WhatsApp 销售智能"
        Width="1440" Height="900" MinWidth="1120" MinHeight="700"
        Icon="/AISalesOS;component/Assets/AI-Sales-OS.ico"
        WindowStartupLocation="CenterScreen" WindowState="Maximized"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResize"
        Background="{DynamicResource Canvas}"
        PreviewKeyDown="MainWindow_PreviewKeyDown">
    <Grid Background="{DynamicResource Canvas}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="244"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Stable product navigation -->
        <Border Grid.Column="0" Background="{DynamicResource Sidebar}">
            <Grid Margin="16,18,16,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="24"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions><ColumnDefinition Width="44"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Width="42" Height="42" Background="{DynamicResource Surface}" CornerRadius="12" Padding="5">
                        <Image Source="/AISalesOS;component/Assets/AI-Sales-OS.png" Stretch="Uniform"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="11,1,0,0" VerticalAlignment="Center">
                            <TextBlock Text="AI Sales OS" Foreground="{DynamicResource SidebarText}" FontWeight="Bold" FontSize="16"/>
                        <TextBlock Text="SALES INTELLIGENCE" Foreground="{DynamicResource SidebarMuted}" FontSize="8.5" FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="COMMAND CENTER" Foreground="{DynamicResource SidebarMuted}" FontSize="9" FontWeight="SemiBold" Margin="13,3,0,7"/>
                        <Button x:Name="DashboardButton" Tag="dashboard" Click="Navigate_Click" Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="▦" Width="26" FontSize="14"/><TextBlock Text="Dashboard"/></StackPanel>
                        </Button>
                        <Button x:Name="IntelligenceButton" Tag="intelligence" Click="Navigate_Click" Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="✦" Width="26" FontSize="14"/><TextBlock Text="商机智能"/></StackPanel>
                        </Button>

                        <TextBlock Text="CUSTOMER OPERATIONS" Foreground="{DynamicResource SidebarMuted}" FontSize="9" FontWeight="SemiBold" Margin="13,20,0,7"/>
                        <Button x:Name="CustomersButton" Tag="customers" Click="Navigate_Click" Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="◎" Width="26" FontSize="14"/><TextBlock Text="客户列表"/></StackPanel>
                        </Button>
                        <Button x:Name="InboxButton" Tag="inbox" Click="Navigate_Click" Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="◉" Width="26" FontSize="14"/><TextBlock Text="WhatsApp Inbox"/></StackPanel>
                        </Button>
                        <Button x:Name="EmailButton" Tag="email" Click="Navigate_Click" Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="✉" Width="26" FontSize="14"/><TextBlock Text="邮件 Inbox"/></StackPanel>
                        </Button>
                        <Button x:Name="BroadcastButton" Tag="broadcast" Click="Navigate_Click" Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="◌" Width="26" FontSize="14"/><TextBlock Text="自动化群发"/></StackPanel>
                        </Button>

                        <TextBlock Text="INSIGHTS" Foreground="{DynamicResource SidebarMuted}" FontSize="9" FontWeight="SemiBold" Margin="13,20,0,7"/>
                        <Button x:Name="AnalyticsButton" Tag="analytics" Click="Navigate_Click" Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="◫" Width="26" FontSize="14"/><TextBlock Text="客户智能分析"/></StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>

                <StackPanel Grid.Row="3">
                    <Button x:Name="VersionButton" Click="VersionHistory_Click" Style="{StaticResource NavButton}" Background="{DynamicResource SidebarElevated}" Margin="0,0,0,9" ToolTip="查看版本与更新">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock x:Name="SidebarUpdateIcon" Text="↻" Foreground="{DynamicResource Success}" FontSize="16" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock x:Name="SidebarVersionText" Text="AI Sales OS" Foreground="{DynamicResource SidebarText}" FontSize="11" FontWeight="SemiBold"/>
                                <TextBlock x:Name="SidebarUpdateText" Text="启动后自动检查更新" Foreground="{DynamicResource SidebarMuted}" FontSize="9.5" Margin="0,3,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="2" Text="›" Foreground="{DynamicResource SidebarMuted}" FontSize="18" VerticalAlignment="Center"/>
                        </Grid>
                    </Button>
                    <Button Content="⌘  快速操作   Ctrl + K" Style="{StaticResource NavButton}" Click="CommandButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Product canvas -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions><RowDefinition Height="72"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Background="{DynamicResource SurfaceElevated}" BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1">
                <Grid Margin="28,0,26,0">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="TopTitle" Text="Dashboard" FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource Ink}"/>
                        <TextBlock x:Name="TopSubtitle" Text="今天最值得推进的商机与动作" Foreground="{DynamicResource Muted}" FontSize="10.5" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border x:Name="ProviderBadge" Background="{DynamicResource WarningSoft}" CornerRadius="13" Padding="11,6" Margin="0,0,9,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✦" Foreground="{DynamicResource AiAccent}" Margin="0,0,6,0"/>
                                <TextBlock x:Name="ProviderText" Text="AI API 未配置" Foreground="{DynamicResource Warning}" FontSize="10.5" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>
                        <Button Style="{StaticResource SecondaryButton}" Click="CommandButton_Click" Margin="0,0,8,0" Padding="13,8" ToolTip="快速操作 (Ctrl+K)">
                            <StackPanel Orientation="Horizontal"><TextBlock Text="快速操作"/><Border Background="{DynamicResource CanvasDeep}" CornerRadius="4" Padding="5,1" Margin="9,0,0,0"><TextBlock Text="Ctrl K" FontSize="9" Foreground="{DynamicResource Muted}"/></Border></StackPanel>
                        </Button>
                        <Button x:Name="ThemeButton" Style="{StaticResource IconButton}" Click="Theme_Click" Margin="0,0,8,0" ToolTip="切换主题"><TextBlock x:Name="ThemeText" Text="◐"/></Button>
                        <Button x:Name="PageGuideButton" Content="本页使用手册" ToolTip="查看当前模块的功能介绍和操作步骤" Style="{StaticResource SecondaryButton}" Click="ShowGuide_Click" Margin="0,0,8,0"/>
                        <Button Content="API 对接" Style="{StaticResource PrimaryButton}" Click="Settings_Click"/>
                    </StackPanel>
                </Grid>
            </Border>
            <ContentControl x:Name="ContentHost" Grid.Row="1"/>
        </Grid>

        <!-- Global and page-specific walkthroughs -->
        <controls:GuideOverlay x:Name="OnboardingGuide" Grid.ColumnSpan="2" Panel.ZIndex="100"/>

        <!-- Keyboard-first command surface -->
        <Grid x:Name="CommandOverlay" Grid.ColumnSpan="2" Panel.ZIndex="120" Background="{DynamicResource Overlay}" Visibility="Collapsed" MouseDown="CommandOverlay_MouseDown">
            <Border Width="600" VerticalAlignment="Top" Margin="0,105,0,0" Style="{StaticResource ElevatedCard}" Padding="0" MouseDown="CommandPanel_MouseDown">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                    <Border BorderBrush="{DynamicResource Line}" BorderThickness="0,0,0,1" Padding="20,17">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBlock Text="⌕" FontSize="20" Foreground="{DynamicResource AiAccent}" Margin="0,0,12,0"/>
                            <TextBlock Grid.Column="1" Text="快速前往或执行操作" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            <Border Grid.Column="2" Background="{DynamicResource CanvasDeep}" CornerRadius="5" Padding="6,2"><TextBlock Text="ESC" FontSize="9" Foreground="{DynamicResource Muted}"/></Border>
                        </Grid>
                    </Border>
                    <StackPanel Grid.Row="1" Margin="10,10,10,4">
                        <TextBlock Text="建议操作" Style="{StaticResource PageEyebrow}" Margin="12,4,0,7"/>
                        <Button Tag="import" Click="QuickAction_Click" Style="{StaticResource GhostButton}" HorizontalContentAlignment="Stretch"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBlock Text="＋" FontSize="18" Foreground="{DynamicResource Primary}"/><StackPanel Grid.Column="1"><TextBlock Text="导入客户数据" FontWeight="SemiBold"/><TextBlock Text="保留 Excel / CSV 原始字段" Foreground="{DynamicResource Muted}" FontSize="10"/></StackPanel><TextBlock Grid.Column="2" Text="Enter" Foreground="{DynamicResource Muted}" VerticalAlignment="Center"/></Grid></Button>
                        <Button Tag="intelligence" Click="QuickAction_Click" Style="{StaticResource GhostButton}" HorizontalContentAlignment="Stretch"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="✦" FontSize="15" Foreground="{DynamicResource AiAccent}"/><StackPanel Grid.Column="1"><TextBlock Text="打开商机智能" FontWeight="SemiBold"/><TextBlock Text="查看 AI 评分证据与下一步" Foreground="{DynamicResource Muted}" FontSize="10"/></StackPanel></Grid></Button>
                        <Button Tag="inbox" Click="QuickAction_Click" Style="{StaticResource GhostButton}" HorizontalContentAlignment="Stretch"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="◉" FontSize="15" Foreground="{DynamicResource Primary}"/><StackPanel Grid.Column="1"><TextBlock Text="打开 WhatsApp Inbox" FontWeight="SemiBold"/><TextBlock Text="处理最新客户回复" Foreground="{DynamicResource Muted}" FontSize="10"/></StackPanel></Grid></Button>
                        <Button Tag="broadcast" Click="QuickAction_Click" Style="{StaticResource GhostButton}" HorizontalContentAlignment="Stretch"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="◌" FontSize="15" Foreground="{DynamicResource Warning}"/><StackPanel Grid.Column="1"><TextBlock Text="建立自动化群发任务" FontWeight="SemiBold"/><TextBlock Text="模板、受众、节奏与人工批准" Foreground="{DynamicResource Muted}" FontSize="10"/></StackPanel></Grid></Button>
                        <Button Tag="analytics" Click="QuickAction_Click" Style="{StaticResource GhostButton}" HorizontalContentAlignment="Stretch"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><TextBlock Text="◫" FontSize="15" Foreground="{DynamicResource AiAccent}"/><StackPanel Grid.Column="1"><TextBlock Text="生成客户情报报告" FontWeight="SemiBold"/><TextBlock Text="整合全部客户数据并导出 Word / PDF" Foreground="{DynamicResource Muted}" FontSize="10"/></StackPanel></Grid></Button>
                    </StackPanel>
                    <Border Grid.Row="2" Background="{DynamicResource SurfaceMuted}" CornerRadius="0,0,16,16" Padding="20,11"><TextBlock Text="Ctrl+1…6 切换模块 · Ctrl+K 打开 · Esc 关闭" Foreground="{DynamicResource Muted}" FontSize="9.5"/></Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
