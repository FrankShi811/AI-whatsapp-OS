<UserControl x:Class="WAFlow.Desktop.Controls.GuideOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="Collapsed">
    <Grid Background="{DynamicResource Overlay}">
        <Border MaxWidth="1080" MaxHeight="720" Margin="28" Style="{StaticResource ElevatedCard}" Padding="0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="7"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="3"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border CornerRadius="16,16,0,0" Background="{DynamicResource AiAccent}"/>

                <Grid Grid.Row="1" Margin="30,22,30,18">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal">
                        <Border Width="46" Height="46" Background="{DynamicResource SurfaceMuted}" CornerRadius="12" Padding="5">
                            <Image Source="/AISalesOS;component/Assets/AI-Sales-OS.png" Stretch="Uniform"/>
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="GuideProductArea" Text="PAGE GUIDE" Style="{StaticResource PageEyebrow}"/>
                            <TextBlock x:Name="GuideHeaderTitle" Text="本页使用手册" FontWeight="Bold" FontSize="18" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                    <Button Grid.Column="1" Content="关闭指南" Style="{StaticResource GhostButton}" Click="Close_Click" VerticalAlignment="Top"/>
                </Grid>

                <Grid Grid.Row="2" Margin="30,0,30,18">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="236"/><ColumnDefinition Width="1"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <Border Background="{DynamicResource CanvasDeep}" CornerRadius="13" Padding="14">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="4,2,4,12">
                                <TextBlock x:Name="GuideStepCounter" Text="第 1 / 4 步" Foreground="{DynamicResource AiAccent}" FontWeight="SemiBold" FontSize="10.5"/>
                                <TextBlock Text="教程目录" FontWeight="SemiBold" Margin="0,5,0,0"/>
                            </StackPanel>
                            <ItemsControl x:Name="GuideStepList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{Binding Background}" CornerRadius="9" Padding="10" Margin="0,0,0,7">
                                            <Grid>
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="29"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                <Border Width="23" Height="23" Background="{Binding NumberBackground}" CornerRadius="7" VerticalAlignment="Top">
                                                    <TextBlock Text="{Binding Number}" Foreground="{Binding NumberForeground}" FontSize="9.5" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Grid.Column="1" Text="{Binding Title}" TextWrapping="Wrap" FontSize="10.5" FontWeight="{Binding FontWeight}" Foreground="{Binding Foreground}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </DockPanel>
                    </Border>
                    <Border Grid.Column="1" Background="{DynamicResource Line}" Margin="18,0"/>

                    <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel Margin="24,2,10,8">
                            <TextBlock x:Name="GuideTitle" Text="欢迎使用" Style="{StaticResource PageTitle}" TextWrapping="Wrap"/>
                            <TextBlock x:Name="GuideSummary" TextWrapping="Wrap" FontSize="13.5" LineHeight="22" Foreground="{DynamicResource InkSecondary}" Margin="0,9,0,0"/>

                            <Border Background="{DynamicResource AiSurface}" BorderBrush="{DynamicResource AiSoft}" BorderThickness="1" CornerRadius="12" Padding="16" Margin="0,17,0,0">
                                <StackPanel>
                                    <TextBlock Text="主要功能" Style="{StaticResource PageEyebrow}"/>
                                    <TextBlock x:Name="GuideFeature" TextWrapping="Wrap" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AiAccentDeep}" Margin="0,7,0,0"/>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="操作步骤" Style="{StaticResource SectionTitle}" Margin="0,19,0,10"/>
                            <ItemsControl x:Name="GuideActionList">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,9">
                                            <Grid.ColumnDefinitions><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                            <Border Width="25" Height="25" Background="{DynamicResource PrimarySoft}" CornerRadius="8" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding Number}" Foreground="{DynamicResource Primary}" FontWeight="Bold" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Grid.Column="1" Text="{Binding Text}" TextWrapping="Wrap" Foreground="{DynamicResource InkSecondary}" FontSize="12.5" LineHeight="19" VerticalAlignment="Center"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Border Background="{DynamicResource WarningSoft}" CornerRadius="10" Padding="13" Margin="0,9,0,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="提示" Foreground="{DynamicResource Warning}" FontWeight="Bold" Margin="0,0,10,0"/>
                                    <TextBlock x:Name="GuideTip" TextWrapping="Wrap" Foreground="{DynamicResource Warning}" FontSize="11" LineHeight="18"/>
                                </StackPanel>
                            </Border>
                            <Button x:Name="GuideSettingsButton" Content="现在配置 AI API" Style="{StaticResource AiButton}" Click="Settings_Click" HorizontalAlignment="Left" Margin="0,15,0,0" Visibility="Collapsed"/>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>

                <ProgressBar Grid.Row="3" Height="3" Value="20" x:Name="GuideProgress" Maximum="100" Foreground="{DynamicResource AiAccent}"/>
                <Grid Grid.Row="4" Margin="30,16,30,22">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="8"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock x:Name="GuideFooter" Foreground="{DynamicResource Muted}" FontSize="9.5" TextWrapping="Wrap"/>
                        <Button x:Name="GlobalGuideButton" Content="查看整套新手入门" Style="{StaticResource GhostButton}" Click="Global_Click" HorizontalAlignment="Left" Padding="0,5" Margin="0,3,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" x:Name="GuideBackButton" Content="上一步" Style="{StaticResource SecondaryButton}" Click="Back_Click"/>
                    <Button Grid.Column="3" x:Name="GuideNextButton" Content="下一步" Style="{StaticResource PrimaryButton}" Click="Next_Click" MinWidth="112"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
