<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="WAFlow.Mac.App"
             RequestedThemeVariant="Light">
  <Application.Styles>
    <FluentTheme />
    <Style Selector="Button.nav">
      <Setter Property="HorizontalContentAlignment" Value="Left" />
      <Setter Property="Height" Value="46" />
      <Setter Property="Padding" Value="16,0" />
      <Setter Property="Margin" Value="0,3" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="#DDEFE8" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="CornerRadius" Value="10" />
    </Style>
    <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#1D5445" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="#0B9B75" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="CornerRadius" Value="9" />
      <Setter Property="Padding" Value="18,10" />
    </Style>
  </Application.Styles>
</Application>
